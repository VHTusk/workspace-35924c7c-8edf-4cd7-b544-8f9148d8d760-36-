# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config

# Security - Never commit sensitive files
*.csv
*.pem
*.key
*.p12
secrets/
credentials/
.env.local
.env.production
.env.*.local

# Uploads with sensitive data
upload/
uploads/

# Database files - NEVER commit
db/*.db
db/*.db-journal
db/*.sqlite
db/*.sqlite3
*.db
*.db-journal
*.sqlite
*.sqlite3

# Backup folders - security risk
.alpha-backup/
.backup/
backup/

# Logs
logs/
*.log
dev.log
server.log

# Non-npm lock files
bun.lock
bun.lockb
yarn.lock
pnpm-lock.yaml

# Generated reports and temp artifacts
*.pdf
*.docx
*.doc
*_report.md
*_audit.md
*_spec.md
*_reference.md

# AI agent artifacts
worklog.md
agent-ctx/

# Skills directory
/skills/

# Local caches
.cache/
.npm/
.eslintcache
*.tsbuildinfo

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Test artifacts
test/
prompt/
playwright-report/
test-results/
