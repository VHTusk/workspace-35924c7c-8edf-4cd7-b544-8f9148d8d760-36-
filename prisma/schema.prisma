model Bracket {
  id              String            @id @default(cuid())
  tournamentId    String            @unique
  format          BracketFormat
  totalRounds     Int
  seedingMethod   String            @default("ELO")
  generatedAt     DateTime          @default(now())
  generatedById   String

  generatedBy     User              @relation("BracketGenerator", fields: [generatedById], references: [id])
  tournament      Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches         BracketMatch[]
}

model BracketMatch {
  id              String              @id @default(cuid())
  bracketId       String
  matchId         String?             @unique
  roundNumber     Int
  matchNumber     Int

  // Individual player references (for INDIVIDUAL format)
  playerAId       String?
  playerBId       String?
  winnerId        String?

  // Team references (for DOUBLES/TEAM format)
  teamAId         String?
  teamBId         String?
  winnerTeamId    String?

  status          BracketMatchStatus  @default(PENDING)
  scheduledAt     DateTime?
  courtAssignment String?
  bracketSide     BracketSide?
  nextMatchId     String?
  loserNextMatchId String?
  rowVersion      Int                 @default(1)

  bracket         Bracket             @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  match           Match?              @relation(fields: [matchId], references: [id])
  teamA           Team?               @relation("BracketTeamA", fields: [teamAId], references: [id])
  teamB           Team?               @relation("BracketTeamB", fields: [teamBId], references: [id])

  @@index([bracketId, roundNumber])
  @@index([bracketId, status])
}

model OrgAdmin {
  id          String        @id @default(cuid())
  orgId       String
  userId      String
  role        OrgAdminRole
  invitedById String
  invitedAt   DateTime      @default(now())
  acceptedAt  DateTime?
  isActive    Boolean       @default(true)

  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id])
  invitedBy   User          @relation("OrgAdminInviter", fields: [invitedById], references: [id])

  @@unique([orgId, userId])
}

model Notification {
  id        String            @id @default(cuid())
  userId    String
  sport     SportType
  type      NotificationType
  title     String
  message   String
  isRead    Boolean           @default(false)
  readAt    DateTime?
  link      String?
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])  // Composite for paginated notification queries
}

model TournamentResult {
  id            String          @id @default(cuid())
  tournamentId  String
  userId        String
  sport         SportType
  rank          Int
  bonusPoints   Int
  awardedAt     DateTime        @default(now())

  tournament    Tournament      @relation(fields: [tournamentId], references: [id])
  user          User            @relation(fields: [userId], references: [id])

  @@unique([tournamentId, rank])
  @@unique([tournamentId, userId])
  @@index([userId])
  @@index([sport])
}

model PrizePayoutRecord {
  id            String        @id @default(cuid())
  tournamentId  String
  userId        String
  sport         SportType
  amount        Int
  method        String
  reference     String?
  paidAt        DateTime
  markedById    String
  createdAt     DateTime      @default(now())

  tournament    Tournament    @relation(fields: [tournamentId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  markedBy      User          @relation("PayoutMarker", fields: [markedById], references: [id])

  @@unique([tournamentId, userId])
  @@index([sport])
}

// Prize Distribution - defines how prize pool is distributed
model PrizeDistribution {
  id            String    @id @default(cuid())
  tournamentId  String
  position      Int       // 1 for 1st, 2 for 2nd, etc.
  percentage    Float     // Percentage of prize pool
  amount        Float     // Calculated amount
  description   String?   // Non-monetary prizes (Trophy, Medal, etc.)
  isMonetary    Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, position])
  @@index([tournamentId])
}

// Prize Payout - tracks actual payout to winners
model PrizePayout {
  id              String        @id @default(cuid())
  tournamentId    String
  userId          String?       // For individual tournaments
  teamId          String?       // For team tournaments
  position        Int
  amount          Float
  status          PayoutStatus  @default(PENDING)
  payoutMethod    String?       // BANK_TRANSFER, UPI, CHEQUE, CASH
  transactionRef  String?       // Transaction reference
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tournament      Tournament    @relation(fields: [tournamentId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])
  team            Team?         @relation(fields: [teamId], references: [id])

  @@index([tournamentId, status])
  @@index([status])
}

model AuditLog {
  id            String        @id @default(cuid())
  sport         SportType
  action        AuditAction
  actorId       String
  actorRole     Role
  targetType    String
  targetId      String
  tournamentId  String?
  operatorName  String?
  operatorEmail String?
  reason        String?
  metadata      String?
  ipAddress     String?
  userAgent     String?       // Browser/client user agent string
  createdAt     DateTime      @default(now())

  actor         User          @relation("AuditActor", fields: [actorId], references: [id])

  @@index([sport, action])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([tournamentId])
  @@index([createdAt])
}

model SportRules {
