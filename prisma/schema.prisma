}

// Personalized Activity Feed Item
model PlayerActivityFeedItem {
  id              String    @id @default(cuid())
  userId          String    // The user whose feed this appears in
  sport           SportType
  
  // Activity details
  type            String    // MATCH_RESULT, TOURNAMENT_WIN, ACHIEVEMENT, FRIEND_ACTIVITY, RANK_CHANGE
  actorId         String?   // Who performed the action
  actorName       String
  title           String
  description     String
  metadata        String?   // JSON for additional data
  
