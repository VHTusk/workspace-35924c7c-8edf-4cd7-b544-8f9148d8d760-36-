  @@index([sport, status, expiresAt])
  @@index([tournamentId, status])
}

// Tournament Recommendation
model PlayerTournamentRecommendation {
  id              String    @id @default(cuid())
  userId          String
  sport           SportType
  tournamentId    String
  
  // Recommendation scoring
  score           Float     // Relevance score
  reason          String    // "Near your location", "Similar skill level", "Friends playing"
  reasonCode      String    // LOCATION, SKILL, FRIENDS, HISTORY, TRENDING
  
  // User interaction
  isViewed        Boolean   @default(false)
  isDismissed     Boolean   @default(false)
  viewedAt        DateTime?
  dismissedAt     DateTime?
  
  createdAt       DateTime  @default(now())
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, tournamentId])
  @@index([userId, isDismissed, createdAt])
}

