// Friend Activity for Social Discovery
model FriendActivity {
  id              String    @id @default(cuid())
  userId          String    @unique  // The active user - one activity record per user
  sport           SportType
  
  // Current status
  status          String    // PLAYING, WATCHING, AVAILABLE, IN_TOURNAMENT
  tournamentId    String?
  tournamentName  String?
  matchId         String?
  
  // Additional info
