  GRACE_PERIOD_STARTED
  NO_SHOW_DETECTED
  NO_SHOW_CONFIRMED
  NO_SHOW_CLEARED
  COURT_ASSIGNED
  COURT_REASSIGNED
  COURT_RELEASED
  MATCH_QUEUED
  MATCH_STARTED
  OVERRIDE_FORCED
  EXTENSION_GRANTED
}

enum PaymentLedgerStatus {
  INITIATED
  PAID
  FAILED
  REFUNDED
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  EXPIRED
  CANCELLED
}

enum NotificationType {
  TOURNAMENT_REGISTERED
  MATCH_RESULT
  POINTS_EARNED
  SUBSCRIPTION_EXPIRY
  DISPUTE_UPDATE
  WAITLIST_PROMOTED
  EMAIL_VERIFIED
  TOURNAMENT_CANCELLED
  REFUND_PROCESSED
  // Team notifications
  TEAM_INVITATION
  TEAM_INVITATION_ACCEPTED
  TEAM_INVITATION_DECLINED
  // Admin notifications
  ADMIN_ASSIGNED
  ADMIN_REMOVED
  // Director notifications
  DIRECTOR_ASSIGNED
  // Emergency/Escalation notifications
  EMERGENCY_CONTROL
  ADMIN_ASSUMPTION
  ESCALATION
  INACTIVITY_WARNING
  // Tournament finalization
  FINALIZATION_WINDOW_OPENED
  FINALIZATION_LOCKED
  DISPUTE_RAISED
  DISPUTE_RESOLVED_NOTIFICATION
  // General
  NEW_FOLLOWER
  RANK_CHANGE
  MILESTONE
  TOURNAMENT_REMINDER
}

enum DisputeStatus {
  OPEN
  REVIEWING
  RESOLVED
}

enum AuditAction {
  // Authentication Events
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_REGISTER
  AUTH_PASSWORD_CHANGE
  AUTH_EMAIL_VERIFY
  AUTH_PASSWORD_RESET
  AUTH_LOGIN_FAILED
  
  // Data Operations
  DATA_ACCESS
  DATA_EXPORT
  DATA_DELETE
  
  // Payment Events
  PAYMENT_CREATE
  PAYMENT_VERIFY
  PAYMENT_REFUND
  
  // Permission/Role Changes
  PERMISSION_CHANGE
  ROLE_CHANGE
  
  // Profile/Settings
  PROFILE_UPDATE
  SETTINGS_CHANGE
  
  // File Operations
  FILE_UPLOAD
  FILE_DOWNLOAD
  FILE_DELETE
  
  // Tournament Events
  TOURNAMENT_CREATE
  TOURNAMENT_REGISTER
  TOURNAMENT_CANCEL
  
  // Admin Actions
  ADMIN_ACTION
  ADMIN_OVERRIDE
  
  // Match/Bracket Events
  MATCH_RESULT_ENTERED
  MATCH_RESULT_EDITED
  MATCH_RESULT_REVERTED
  BRACKET_GENERATED
  BRACKET_DELETED
  BRACKET_RESET
  TOURNAMENT_COMPLETED
  PRIZE_PAYOUT_RECORDED
  DISPUTE_RESOLVED
  
