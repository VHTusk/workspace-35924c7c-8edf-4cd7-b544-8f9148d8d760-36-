// ============================================
// CROSS-SPORT IDENTITY SUSPENSION
// ============================================

// Suspended identities - cross-sport ban propagation
// When a user is banned in one sport, their email/phone is added here
// This prevents them from registering in any other sport
model SuspendedIdentity {
  id              String    @id @default(cuid())
  identifier      String    // Normalized email or phone
  identifierType  String    // 'EMAIL' or 'PHONE'
  reason          String    // Reason for suspension
  suspendedAt     DateTime  @default(now())
  expiresAt       DateTime? // For temporary suspensions
  suspendedById   String    // Admin who issued the suspension
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([identifier, identifierType])
  @@index([identifier])
}

// ============================================
// ELO JOB QUEUE SYSTEM
// ============================================

// Job status for ELO calculation jobs
enum JobStatus {
  PENDING       // Job is waiting to be processed
  PROCESSING    // Job is currently being processed
  COMPLETED     // Job completed successfully
  FAILED        // Job failed but may be retried
  DEAD_LETTER   // Job failed max attempts, moved to dead letter queue
}

// ELO calculation job queue
// Supports poison pill recovery - jobs stuck in PROCESSING for > 60s are recovered
// UNIQUE constraint on matchId ensures idempotent ELO processing (one job per match)
model EloJob {
  id            String      @id @default(cuid())
  matchId       String      @unique  // Match that triggered ELO calculation - UNIQUE for idempotency
  status        JobStatus   @default(PENDING)
  attempts      Int         @default(0)
  maxAttempts   Int         @default(5)
  lastError     String?     // Last error message if failed
  processedAt   DateTime?   // When job was successfully processed
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status, createdAt])
}

// ============================================
// COMPLETION & TRUST LAYER (v3.48.0)
// ============================================

// Finalization status for tournament results
enum FinalizationStatus {
  PENDING       // Tournament just completed, window not started
  WINDOW_OPEN   // Finalization window is active (disputes allowed)
  WINDOW_CLOSED // Finalization window closed, ready to lock
  LOCKED        // Results are locked and immutable
  DISPUTED      // Active dispute blocking finalization
  OVERRIDDEN    // Admin override applied
}

// Types of completion actions
enum CompletionAction {
  TOURNAMENT_COMPLETED    // Tournament marked as completed
  WINNER_CONFIRMED        // Winner confirmed
  SNAPSHOT_CAPTURED       // Results snapshot captured
  FINALIZATION_STARTED    // Finalization window started
  FINALIZATION_LOCKED     // Results locked
  DISPUTE_RAISED          // Dispute raised
  DISPUTE_RESOLVED        // Dispute resolved
  RECOGNITION_AWARDED     // Titles/achievements awarded
  RECAP_GENERATED         // Tournament recap generated
  ADMIN_OVERRIDE          // Admin override applied
  UNLOCK_GRANTED          // Results unlocked by admin
}

// Types of recognition awards
enum RecognitionType {
  TITLE           // Geographic title (State Champion, etc.)
  ACHIEVEMENT     // Achievement badge
  RANKING_POINTS  // Ranking points update
  TROPHY          // Virtual trophy
  MILESTONE       // Milestone recognition
}

// Tournament Snapshot - Immutable historical record
model TournamentSnapshot {
  id              String    @id @default(cuid())
  tournamentId    String    @unique
  sport           SportType
  
  // Snapshot data (JSON)
  finalStandings  String    // JSON: [{rank, playerId/teamId, playerName/teamName, points}]
  bracketState    String    // JSON: Complete bracket state at completion
  matchResults    String    // JSON: All match results
  statistics      String    // JSON: Tournament statistics
  
  // Metadata
  capturedAt      DateTime  @default(now())
  snapshotVersion String    @default("1.0")  // For future schema migrations
  
  // Integrity
  checksum        String    // Hash for data integrity verification
  
  // Lock status
  lockedAt        DateTime?
  lockedById      String?   // Admin who locked (if manual)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([sport, capturedAt])
  @@index([tournamentId])
}

// Finalization Window - Tracks the dispute window period
model FinalizationWindow {
  id                  String              @id @default(cuid())
  tournamentId        String              @unique
  sport               SportType
  
  // Window timing
  windowStartsAt      DateTime            // When window opens
  windowEndsAt        DateTime            // When window closes (default: 48h)
  customDuration      Int?                // Custom duration in hours (if not 48)
  
  // Status
  status              FinalizationStatus  @default(PENDING)
  
  // Dispute tracking
  totalDisputes       Int                 @default(0)
  activeDisputes      Int                 @default(0)
  resolvedDisputes    Int                 @default(0)
  
  // Lock tracking
  lockedAt            DateTime?
  lockedById          String?
  lockReason          String?
  
  // Unlock tracking (for admin corrections)
  unlockedAt          DateTime?
  unlockedById        String?
  unlockReason        String?
  unlockExpiresAt     DateTime?           // Temporary unlock expires
  
  // Notifications sent
  windowOpenedNotif   Boolean             @default(false)
  windowClosingNotif  Boolean             @default(false)  // 6 hours before close
  windowClosedNotif   Boolean             @default(false)
  
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  @@index([status, windowEndsAt])
  @@index([sport, status])
}

// Tournament Dispute - Enhanced dispute for tournament results
model TournamentDispute {
  id                  String          @id @default(cuid())
  tournamentId        String
  sport               SportType
  
  // Dispute details
  raisedById          String          // Player raising dispute
  disputedEntityId    String?         // Player or team being disputed
  disputeType         String          // 'RESULT', 'PLACEMENT', 'ELIGIBILITY', 'CONDUCT'
  reason              String
  evidence            String?         // JSON array of evidence URLs/attachments
  
  // Resolution
  status              DisputeStatus   @default(OPEN)
  resolution          String?
  resolvedById        String?
  resolvedAt          DateTime?
  
  // Impact on finalization
  blocksFinalization  Boolean         @default(true)
  
  // Audit trail
  reviewedById        String?         // First reviewer
  reviewedAt          DateTime?
  escalationLevel     Int             @default(0)  // 0=Director, 1=State, 2=Zone, etc.
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  
  @@index([tournamentId, status])
  @@index([raisedById])
  @@index([status, createdAt])
}

// Completion Log - Audit trail for all completion actions
model TournamentCompletionLog {
  id              String            @id @default(cuid())
  tournamentId    String
  sport           SportType
  
  // Action details
  action          CompletionAction
  status          String            // 'SUCCESS', 'FAILED', 'SKIPPED'
  details         String?           // JSON details
  
  // Actor
  actorId         String?           // null for system actions
  actorRole       String?           // 'SYSTEM', 'DIRECTOR', 'ADMIN', etc.
  
  // Error tracking
  errorMessage    String?
  
  // Timestamp
  executedAt      DateTime          @default(now())
  
  @@index([tournamentId, executedAt])
  @@index([action, status])
}

// Tournament State Log - History of all tournament state transitions
model TournamentStateLog {
  id              String          @id @default(cuid())
  tournamentId    String
  sport           SportType
  
  // State transition
  fromState       TournamentStatus
  toState         TournamentStatus
  
  // Who made the change
  changedById     String          // User ID of who changed the state
  
  // Why the change was made
  reason          String?
  
  // Additional context
  metadata        String?         // JSON: { autopilot: true, triggeredBy: "registration_deadline", ... }
  
  // Timestamp
  createdAt       DateTime        @default(now())
  
  @@index([tournamentId, createdAt])
  @@index([sport, createdAt])
  @@index([fromState, toState])
}

// Recognition Award - Auto-generated titles and achievements
model RecognitionAward {
  id                  String            @id @default(cuid())
  tournamentId        String
  sport               SportType
  
  // Recipient
  recipientId         String            // Player or team ID
  recipientType       String            // 'PLAYER' or 'TEAM'
  
  // Award details
  recognitionType     RecognitionType
  title               String            // Title name (e.g., "State Champion")
  description         String?
  
  // Scope
  scope               TournamentScope?  // CITY, DISTRICT, STATE, NATIONAL
  scopeValue          String?           // e.g., "Rajasthan", "Jaipur"
  
  // Validity
  validFrom           DateTime          @default(now())
  validUntil          DateTime?         // For temporary titles
  isActive            Boolean           @default(true)
  
  // Revocation
  revokedAt           DateTime?
  revokedById         String?
  revocationReason    String?
  
  // Source
  triggeredBy         String            @default("TOURNAMENT_COMPLETION")
  metadata            String?           // JSON additional data
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  @@index([recipientId, recipientType, isActive])
  @@index([sport, recognitionType, isActive])
  @@index([tournamentId])
}

// Player Completion Stats - Aggregate tournament completion statistics
model PlayerCompletionStats {
  id                    String    @id @default(cuid())
  playerId              String    @unique
  sport                 SportType
  
  // Tournament stats
  tournamentsPlayed     Int       @default(0)
  tournamentsWon        Int       @default(0)
  tournamentsPodium     Int       @default(0)  // Top 3 finishes
  
  // Final positions
  firstPlace            Int       @default(0)
  secondPlace           Int       @default(0)
  thirdPlace            Int       @default(0)
  
  // Recognition stats
  titlesHeld            Int       @default(0)
  achievementsEarned    Int       @default(0)
  
  // Dispute stats
  disputesRaised        Int       @default(0)
  disputesWon           Int       @default(0)
  
  // Trust score (based on dispute history, completion rate, etc.)
  trustScore            Float     @default(100.0)  // Starts at 100
  
  lastTournamentAt      DateTime?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([sport, tournamentsWon])
  @@index([sport, trustScore])
}

// ============================================
// FINANCIAL SAFETY LAYER (v3.49.0)
// ============================================

// Refund processing status
enum RefundStatus {
  PENDING       // Queued for processing
  INITIATED     // Sent to Razorpay
  PROCESSING    // Razorpay processing
  COMPLETED     // Refund successful
  FAILED        // Refund failed
  MANUAL_REVIEW // Requires manual intervention
  CANCELLED     // Refund cancelled
}

// Refund mode - auto or manual
enum RefundMode {
  AUTO          // Automatically process refunds
  MANUAL        // Require admin approval for each refund
}

// Cancellation reason categories
enum CancellationReason {
  ORGANIZER_DECISION    // Organizer cancelled
  INSUFFICIENT_PLAYERS  // Not enough registrations
  VENUE_UNAVAILABLE     // Venue issue
  WEATHER               // Weather/force majeure
  GOVERNMENT_ORDER      // Regulatory
  SYSTEM_ERROR          // Technical issue
  OTHER                 // Other reasons
}

// Payment recovery status
enum RecoveryStatus {
  PENDING       // Recovery job pending
  IN_PROGRESS   // Currently being processed
  RECOVERED     // Successfully recovered
  FAILED        // Recovery failed
  EXPIRED       // Payment expired without recovery
}

// Refund Policy Configuration
model RefundPolicy {
  id                      String    @id @default(cuid())
  tournamentId            String?   @unique  // null = global default
  
  // Auto/Manual mode
  refundMode              RefundMode @default(MANUAL)
  
  // Refund percentages by timing (0-100)
  beforeRegDeadline       Float     @default(100)
  afterRegBeforeStart     Float     @default(100)
  afterStartPartial       Float     @default(50)
  afterStartComplete      Float     @default(0)
  
  // Deductions
  platformFeePercent      Float     @default(0)    // Platform fee on refunds
  processingFeeFixed      Int       @default(0)    // Fixed processing fee
  
  // Timing thresholds
  partialRefundHours      Int       @default(24)   // Hours before start
  
  // Mid-tournament refund
  proRataMatchRefund      Boolean   @default(false) // Refund based on matches played
  minMatchesForRefund     Int       @default(0)    // Minimum matches for partial refund
  
  // Created/Updated
  createdById             String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  
  // Relations
  tournament              Tournament? @relation(fields: [tournamentId], references: [id])
  
  @@index([tournamentId])
  @@index([refundMode])
}

// Refund Job - Tracks individual refund processing
model RefundJob {
  id                      String        @id @default(cuid())
  tournamentId            String
  registrationId          String?
  teamRegistrationId      String?
  playerId                String?
  teamId                  String?
  
  // Amount details
  originalAmount          Int           // Amount paid
  refundAmount            Int           // Amount to refund
  platformFee             Int           @default(0)
  processingFee           Int           @default(0)
  netRefund               Int           // Actual refund amount
  
  // Status tracking
  status                  RefundStatus  @default(PENDING)
  razorpayRefundId        String?       // Razorpay refund ID
  razorpayPaymentId       String?       // Original payment ID
  
  // Retry tracking
  retryCount              Int           @default(0)
  maxRetries              Int           @default(5)
  lastRetryAt             DateTime?
  nextRetryAt             DateTime?
  lastError               String?
  
  // Approval (for manual mode)
  approvedById            String?
  approvedAt              DateTime?
  approvalNotes           String?
  
  // Timing
  initiatedAt             DateTime?
  completedAt             DateTime?
  
  // Audit
  cancellationReason      CancellationReason?
  cancellationNotes       String?
  
  // Relations
  tournament              Tournament    @relation(fields: [tournamentId], references: [id])
  
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  
  @@index([tournamentId, status])
  @@index([status, nextRetryAt])
  @@index([razorpayPaymentId])
}

// Payment Recovery - Tracks failed webhooks and recovery attempts
model PaymentRecovery {
  id                      String          @id @default(cuid())
  tournamentId            String?
  registrationId          String?
  
  // Payment details
  razorpayOrderId         String?
  razorpayPaymentId       String?
  amount                  Int
  
  // Status
  status                  RecoveryStatus  @default(PENDING)
  
  // Original webhook data (stored for replay)
  webhookPayload          String?         // JSON of original webhook
  
  // Recovery tracking
  recoveryAttempts        Int             @default(0)
  maxAttempts             Int             @default(5)
  lastAttemptAt           DateTime?
  nextAttemptAt           DateTime?
  lastError               String?
  
  // Resolution
  resolvedAt              DateTime?
  resolvedById            String?
  resolutionNotes         String?
  
  // Relations
  tournament              Tournament?     @relation(fields: [tournamentId], references: [id])
  
  // Timestamps
  originalWebhookAt       DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  
  @@index([status, nextAttemptAt])
  @@index([razorpayPaymentId])
  @@index([registrationId])
}

// Tournament Finance Snapshot - Complete financial record
model TournamentFinanceSnapshot {
  id                      String    @id @default(cuid())
  tournamentId            String    @unique
  sport                   SportType
  
  // Collections
  grossCollections        Int       @default(0)    // Total amount collected
  platformFeesCollected   Int       @default(0)    // Platform fee income
  paymentGatewayFees      Int       @default(0)    // Razorpay fees
  netCollections          Int       @default(0)    // After gateway fees
  
  // Entry breakdown
  entryFeesTotal          Int       @default(0)
  earlyBirdTotal          Int       @default(0)
  addOnsTotal             Int       @default(0)
  
  // Player breakdown
  totalRegistrations      Int       @default(0)
  paidRegistrations       Int       @default(0)
  freeRegistrations       Int       @default(0)
  
  // Refunds
  totalRefundsInitiated   Int       @default(0)
  totalRefundsCompleted   Int       @default(0)
  totalRefundAmount       Int       @default(0)
  pendingRefundAmount     Int       @default(0)
  
  // Prize pool
  prizePoolCollected      Int       @default(0)
  prizePoolPaid           Int       @default(0)
  prizePoolPending        Int       @default(0)
  
  // Net position
  organizerPayout         Int       @default(0)
  platformRevenue         Int       @default(0)
  
  // Reconciliation
  reconciledAt            DateTime?
  reconciledById          String?
  reconciliationStatus    String    @default("PENDING")  // PENDING, MATCHED, DISCREPANCY
  discrepancyNotes        String?
  
  // Relations
  tournament              Tournament @relation(fields: [tournamentId], references: [id])
  
  // Audit trail
  capturedAt              DateTime  @default(now())
  lockedAt                DateTime?
  
  @@index([sport, capturedAt])
  @@index([reconciliationStatus])
}

// Cancellation Log - Tracks tournament cancellations
model CancellationLog {
  id                      String            @id @default(cuid())
  tournamentId            String
  sport                   SportType
  
  // Cancellation details
  reason                  CancellationReason
  notes                   String?
  
  // Timing
  cancelledAt             DateTime          @default(now())
  cancelledById           String
  
  // Impact
  totalRegistrations      Int               @default(0)
  totalPaid               Int               @default(0)
  totalAmount             Int               @default(0)
  
  // Refund summary
  refundMode              RefundMode
  refundsInitiated        Int               @default(0)
  refundsPending          Int               @default(0)
  refundsCompleted        Int               @default(0)
  
  // Notification status
  playersNotified         Boolean           @default(false)
  notifiedAt              DateTime?
  
  // Relations
  tournament              Tournament        @relation(fields: [tournamentId], references: [id])
  
  createdAt               DateTime          @default(now())
  
  @@index([tournamentId])
  @@index([cancelledAt])
}


// ============================================
// GOVERNANCE AUTOMATION LAYER (v3.50.0)
// ============================================

// Director Assignment Rule - Rules for auto-assigning directors
model DirectorAssignmentRule {
  id                  String   @id @default(cuid())
  sport               SportType
  
  // Geographic scope
  stateCode           String?
  districtName        String?
  
  // Assignment criteria
  minTrustLevel       Int      @default(0)  // Minimum trust level required
  requireAvailability Boolean  @default(true)
  maxDistanceKm       Int?     // Maximum distance from venue
  
  // Priority weights for scoring
  distanceWeight      Float    @default(0.3)
  trustWeight         Float    @default(0.3)
  loadWeight          Float    @default(0.2)
  experienceWeight    Float    @default(0.2)
  
  // Fallback behavior
  fallbackToStateAdmin Boolean @default(true)
  fallbackToZoneAdmin  Boolean @default(true)
  fallbackToSportAdmin Boolean @default(true)
  
  // Manual override allowed
  allowManualOverride  Boolean @default(true)
  
  isActive            Boolean  @default(true)
  createdById         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([sport, stateCode, districtName])
  @@index([isActive])
}

// Admin Inactivity Flag - Track and flag inactive admins
model AdminInactivityFlag {
  id                  String   @id @default(cuid())
  adminId             String   // AdminAssignment ID
  userId              String
  
  // Detection metrics
  lastLoginAt         DateTime?
  lastActionAt        DateTime?
  daysInactive        Int      @default(0)
  pendingEscalations  Int      @default(0)
  unrespondedActions  Int      @default(0)
  
  // Flag status
  status              InactivityStatus @default(MONITORING)
  flaggedAt           DateTime?
  flaggedById         String?  // Auto-flagged if null
  
  // Escalation
  escalationLevel     AdminRole?  // Level escalated to
  escalatedAt         DateTime?
  
  // Resolution
  resolvedAt          DateTime?
  resolvedById        String?
  resolutionNotes     String?
  
  // Auto-actions taken
  autoDisabled        Boolean  @default(false)
  authorityTransferred Boolean @default(false)
  transferredToId     String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@unique([adminId])
  @@index([status, daysInactive])
  @@index([userId])
}

enum InactivityStatus {
  MONITORING       // Watching for inactivity
  WARNING          // Warning sent to admin
  FLAGGED          // Flagged for escalation
  ESCALATED        // Authority escalated
  RESOLVED         // Admin responded/resolved
  DISABLED         // Admin disabled
}

// Region Load Metric - Track admin workload for load balancing
model RegionLoadMetric {
  id                    String   @id @default(cuid())
  adminId               String   // AdminAssignment ID
  userId                String
  
  // Current load
  activeTournaments     Int      @default(0)
  pendingActions        Int      @default(0)
  openEscalations       Int      @default(0)
  scheduledToday        Int      @default(0)
  scheduledThisWeek     Int      @default(0)
  
  // Capacity
  maxCapacity           Int      @default(10)
  currentLoadPercent    Float    @default(0)
  
  // Performance
  avgResponseTimeMin    Float    @default(0)
  actionsToday          Int      @default(0)
  actionsThisWeek       Int      @default(0)
  
  // Historical
  tournamentsHandled    Int      @default(0)
  escalationsResolved   Int      @default(0)
  
  // Time period
  periodStart           DateTime @default(now())
  periodEnd             DateTime?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([adminId, periodStart])
  @@index([userId, periodStart])
  @@index([currentLoadPercent])
}

// Emergency Control Log - Track emergency control transfers
model EmergencyControlLog {
  id                    String   @id @default(cuid())
  
  // Source (disabled/unavailable admin)
  originalAdminId       String?
  originalRole          AdminRole
  originalStateCode     String?
  originalDistrictName  String?
  
  // Target (assuming authority)
  assumingAdminId       String
  assumingRole          AdminRole
  
  // Trigger
  triggerType           EmergencyTriggerType
  triggerDescription    String
  triggeredAt           DateTime @default(now())
  triggeredById         String?  // Auto if system-triggered
  
  // Scope
  affectedTournaments   Int      @default(0)
  affectedPlayers       Int      @default(0)
  affectedRegions       String?  // JSON array of affected regions
  
  // Duration
  estimatedDuration     Int?     // In hours
  actualEndTime         DateTime?
  
  // Status
  status                EmergencyStatus @default(ACTIVE)
  resolvedAt            DateTime?
  resolvedById          String?
  resolutionNotes       String?
  
  // Notifications
  superAdminNotified    Boolean  @default(false)
  sportAdminNotified    Boolean  @default(false)
  affectedAdminsNotified Boolean @default(false)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([status, triggeredAt])
  @@index([originalRole, originalStateCode])
  @@index([assumingAdminId])
}

enum EmergencyTriggerType {
  ADMIN_DISABLED         // Admin was manually disabled
  INACTIVITY_TIMEOUT     // Admin didn't respond in time
  SYSTEM_FAILURE         // Regional system failure
  REGIONAL_EMERGENCY     // Natural disaster, etc.
  SECURITY_INCIDENT      // Security breach detected
  VOLUNTARY_TRANSFER     // Admin requested transfer
  SCHEDULE_CONFLICT      // Overlapping events
}

enum EmergencyStatus {
  ACTIVE               // Emergency control in effect
  PARTIAL              // Partial transfer
  RESOLVED             // Normal control restored
  ESCALATED            // Further escalated
}

// Auto Director Assignment Log - Track automatic assignments
model AutoDirectorAssignmentLog {
  id                    String   @id @default(cuid())
  tournamentId          String
  
  // Assignment process
  assignmentType        DirectorAssignmentType @default(AUTO)
  
  // Candidates considered
  candidatesConsidered  Int      @default(0)
  candidateScores       String?  // JSON: [{adminId, score, breakdown}]
  
  // Selected director
  selectedAdminId       String
  selectedScore         Float
  selectionReason       String
  
  // Override
  overriddenBy          String?
  overriddenAt          DateTime?
  overrideReason        String?
  finalAdminId          String?  // If overridden
  
  // Timing
  assignedAt            DateTime @default(now())
  
  createdAt             DateTime @default(now())
  
  @@index([tournamentId])
  @@index([selectedAdminId])
  @@index([assignedAt])
}

enum DirectorAssignmentType {
  AUTO                 // Fully automatic
  AUTO_WITH_OVERRIDE   // Auto-suggested, manually overridden
  MANUAL               // Fully manual selection
  ESCALATION           // Assigned via escalation
}

// ============================================
// CORPORATE MODE ENUMS (v3.54.0)
// ============================================

enum EmployeeInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum SquadStatus {
  ACTIVE
  INACTIVE
  DISBANDED
}

enum RepPlayerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INJURED
}

enum RepPlayerType {
  EMPLOYEE_REP     // Employee representing org
  CONTRACT_PLAYER  // External player with contract
}

// ============================================
// CORPORATE MODE MODELS (v3.54.0)
// ============================================

// LAYER 1: EMPLOYER SPORTS - Employee Management

// Employee Record - Verified employees of the organization
model Employee {
  id              String   @id @default(cuid())
  orgId           String
  userId          String?  // Link to User account (null if not registered)
  sport           SportType
  
  // Employee Details
  employeeId      String?  // Company employee ID
  email           String
  firstName       String
  lastName        String
  phone           String?
  department      String?
  designation     String?
  
  // Verification
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?  // OrgAdmin who verified
  
  // Status
  isActive        Boolean  @default(true)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?
  
  // Relations
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User?        @relation(fields: [userId], references: [id])
  invitations     EmployeeInvitation[]
  tournamentParticipations EmployeeTournamentParticipation[]
  sportPlayers    SportPlayer[]  // Sport-specific player mappings
  
  @@unique([orgId, email, sport])
  @@index([orgId, isActive])
  @@index([email, sport])
}

// Employee Invitation - Invite employees to tournaments
model EmployeeInvitation {
  id              String                  @id @default(cuid())
  orgId           String
  tournamentId    String
  employeeId      String
  sport           SportType
  
  // Invitation
  status          EmployeeInvitationStatus @default(PENDING)
  invitedAt       DateTime                @default(now())
  invitedBy       String  // OrgAdmin userId
  expiresAt       DateTime
  respondedAt     DateTime?
  
  // Communication
  emailSent       Boolean @default(false)
  emailSentAt     DateTime?
  reminderSent    Boolean @default(false)
  reminderSentAt  DateTime?
  
  // Response
  responseMessage String?
  
  // Relations
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tournament      Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  employee        Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([tournamentId, employeeId])
  @@index([orgId, status])
  @@index([employeeId, status])
  @@index([status, expiresAt])
}

// Employee Tournament Participation
model EmployeeTournamentParticipation {
  id              String   @id @default(cuid())
  employeeId      String
  tournamentId    String
  sport           SportType
  
  registeredAt    DateTime @default(now())
  result          String?  // JSON with match results
  rank            Int?
  pointsEarned    Int      @default(0)
  
  employee        Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, tournamentId])
  @@index([tournamentId])
}

// LAYER 2: COMPETITIVE REPRESENTATION - Squad Management

// Rep Squad - Sport-wise competitive squad
model RepSquad {
  id              String      @id @default(cuid())
  orgId           String
  sport           SportType
  name            String      // Squad name e.g., "ValorHive Pro Darts Team"
  
  // Squad Details
  description     String?
  logoUrl         String?
  
  // Status
  status          SquadStatus @default(ACTIVE)
  formedAt        DateTime    @default(now())
  disbandedAt     DateTime?
  
  // Stats
  matchesPlayed   Int         @default(0)
  wins            Int         @default(0)
  losses          Int         @default(0)
  tournamentsParticipated Int @default(0)
  tournamentsWon  Int         @default(0)
  
  // Management
  managerId       String?     // User ID of squad manager
  coachId         String?     // User ID of coach
  
  // Relations
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  players         RepPlayer[]
  tournamentRegistrations RepSquadTournamentRegistration[]
  
  @@unique([orgId, sport, name])
  @@index([orgId, sport, status])
}

// Rep Player - Player in representation pool
model RepPlayer {
  id              String          @id @default(cuid())
  squadId         String
  userId          String
  
  // Player Type
  playerType      RepPlayerType   @default(EMPLOYEE_REP)
  
  // Status
  status          RepPlayerStatus @default(ACTIVE)
  joinedAt        DateTime        @default(now())
  leftAt          DateTime?
  
  // For Contract Players
  contractId      String?         // Link to PlayerContract
  contractStartDate DateTime?
  contractEndDate   DateTime?
  
  // Player Role
  role            String          @default("PLAYER") // PLAYER, CAPTAIN, VICE_CAPTAIN
  
  // Stats
  matchesPlayed   Int             @default(0)
  wins            Int             @default(0)
  losses          Int             @default(0)
  
  // Relations
  squad           RepSquad        @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id])
  
  @@unique([squadId, userId])
  @@index([squadId, status])
  @@index([userId])
  @@index([playerType, status])
}

// Rep Squad Tournament Registration
model RepSquadTournamentRegistration {
  id              String            @id @default(cuid())
  squadId         String
  tournamentId    String
  
  // Registration
  status          RegistrationStatus @default(PENDING)
  registeredAt    DateTime          @default(now())
  registeredBy    String            // OrgAdmin userId
  
  // Payment
  paymentId       String?
  amount          Int               @default(0)
  
  // Result
  finalRank       Int?
  prizeWon        Int               @default(0)
  
  // Relations
  squad           RepSquad          @relation(fields: [squadId], references: [id], onDelete: Cascade)
  tournament      Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  
  @@unique([squadId, tournamentId])
  @@index([tournamentId, status])
}

// ============================================
// SCHOOL MODELS (v3.55.0)
// ============================================

// School Class - e.g., Class 1, Class 2... Class 12
model SchoolClass {
  id              String   @id @default(cuid())
  orgId           String
  sport           SportType
  
  // Class Details
  name            String   // "Class 1", "Class 10", etc.
  gradeLevel      Int      // 1-12
  
  // Status
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sections        SchoolSection[]
  students        Student[]
  
  @@unique([orgId, gradeLevel, sport])
  @@index([orgId, isActive])
}

// School Section - e.g., Section A, Section B within a class
model SchoolSection {
  id              String   @id @default(cuid())
  classId         String
  orgId           String
  sport           SportType
  
  // Section Details
  name            String   // "A", "B", "C"
  capacity        Int?
  
  // Status
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  schoolClass     SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  students        Student[]
  
  @@unique([classId, name])
  @@index([orgId, isActive])
}

// School House - e.g., Red House, Blue House for inter-house competitions
model SchoolHouse {
  id              String   @id @default(cuid())
  orgId           String
  sport           SportType
  
  // House Details
  name            String   // "Red House", "Blue House", etc.
  color           String?  // Hex color code
  logoUrl         String?
  motto           String?
  
  // Stats
  points          Int      @default(0)
  tournamentsWon  Int      @default(0)
  
  // Status
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  students        Student[]
  
  @@unique([orgId, name, sport])
  @@index([orgId, isActive])
}

// ============================================
// COLLEGE MODELS (v3.55.0)
// ============================================

// College Department - e.g., Engineering, Arts, Science
model CollegeDepartment {
  id              String   @id @default(cuid())
  orgId           String
  sport           SportType
  
  // Department Details
  name            String   // "Engineering", "Arts", "Science"
  code            String?  // "ENG", "ARTS", "SCI"
  
  // Stats
  totalStudents   Int      @default(0)
  
  // Status
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  batches         CollegeBatch[]
  students        Student[]
  
  @@unique([orgId, name, sport])
  @@index([orgId, isActive])
}

// College Batch - e.g., 2021-2025, 2022-2026
model CollegeBatch {
  id              String   @id @default(cuid())
  departmentId    String
  orgId           String
  sport           SportType
  
  // Batch Details
  name            String   // "2021-2025", "2022-2026"
  startYear       Int
  endYear         Int
  
  // Stats
  totalStudents   Int      @default(0)
  
  // Status
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  department      CollegeDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  students        Student[]
  
  @@unique([departmentId, startYear])
  @@index([orgId, isActive])
}

// ============================================
// STUDENT MODEL (v3.55.0) - Works for both School and College
// ============================================

enum StudentType {
  SCHOOL_STUDENT
  COLLEGE_STUDENT
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  TRANSFERRED
  DROPPED
}

// Student Record - For schools and colleges
model Student {
  id              String        @id @default(cuid())
  orgId           String
  userId          String?       @unique  // Link to User account (null if not registered)
  sport           SportType
  studentType     StudentType
  
  // Student Details
  enrollmentId    String?       // Roll number / enrollment number
  email           String
  firstName       String
  lastName        String
  phone           String?
  dob             DateTime?
  gender          GenderCategory?
  
  // School-specific (null for college students)
  classId         String?       // Reference to SchoolClass
  sectionId       String?       // Reference to SchoolSection
  houseId         String?       // Reference to SchoolHouse
  
  // College-specific (null for school students)
  departmentId    String?       // Reference to CollegeDepartment
  batchId         String?       // Reference to CollegeBatch
  year            Int?          // Current year (1st, 2nd, 3rd, 4th)
  
  // Verification
  isVerified      Boolean       @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?       // OrgAdmin who verified
  
  // Status
  status          StudentStatus @default(ACTIVE)
  joinedAt        DateTime      @default(now())
  leftAt          DateTime?
  
  // Stats
  tournamentsPlayed Int         @default(0)
  matchesWon        Int         @default(0)
  matchesLost       Int         @default(0)
  totalPoints       Int         @default(0)
  
  // Relations
  organization    Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id])
  schoolClass     SchoolClass?  @relation(fields: [classId], references: [id])
  schoolSection   SchoolSection? @relation(fields: [sectionId], references: [id])
  schoolHouse     SchoolHouse?  @relation(fields: [houseId], references: [id])
  department      CollegeDepartment? @relation(fields: [departmentId], references: [id])
  batch           CollegeBatch? @relation(fields: [batchId], references: [id])
  teamMemberships AcademicTeamMember[]
  
  @@unique([orgId, email, sport])
  @@index([orgId, status])
  @@index([orgId, studentType])
  @@index([email, sport])
}

// ============================================
// ACADEMIC TEAM MODELS (v3.55.0)
// ============================================

// Academic Team Status
enum AcademicTeamStatus {
  ACTIVE
  INACTIVE
  DISBANDED
}

// School Team - For inter-school tournaments
model SchoolTeam {
  id              String            @id @default(cuid())
  orgId           String
  sport           SportType
  name            String            // "Delhi Public School A Team"
  
  // Team Details
  description     String?
  logoUrl         String?
  
  // Status
  status          AcademicTeamStatus @default(ACTIVE)
  formedAt        DateTime          @default(now())
  disbandedAt     DateTime?
  
  // Stats
  matchesPlayed   Int               @default(0)
  wins            Int               @default(0)
  losses          Int               @default(0)
  tournamentsParticipated Int       @default(0)
  tournamentsWon  Int               @default(0)
  
  // Management
  coachId         String?           // User ID of coach
  
  // Relations
  organization    Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Note: players and registrations are queried via AcademicTeamMember and AcademicTeamRegistration
  // using teamId and teamType="SCHOOL"
  
  @@unique([orgId, sport, name])
  @@index([orgId, sport, status])
}

// College Team - For inter-college tournaments
model CollegeTeam {
  id              String            @id @default(cuid())
  orgId           String
  sport           SportType
  name            String            // "IIT Delhi Darts Team"
  
  // Team Details
  description     String?
  logoUrl         String?
  
  // Status
  status          AcademicTeamStatus @default(ACTIVE)
  formedAt        DateTime          @default(now())
  disbandedAt     DateTime?
  
  // Stats
  matchesPlayed   Int               @default(0)
  wins            Int               @default(0)
  losses          Int               @default(0)
  tournamentsParticipated Int       @default(0)
  tournamentsWon  Int               @default(0)
  
  // Management
  coachId         String?           // User ID of coach
  
  // Relations
  organization    Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // Note: players and registrations are queried via AcademicTeamMember and AcademicTeamRegistration
  // using teamId and teamType="COLLEGE"
  
  @@unique([orgId, sport, name])
  @@index([orgId, sport, status])
}

// Academic Team Member - Player in school/college team
model AcademicTeamMember {
  id              String   @id @default(cuid())
  studentId       String
  teamId          String
  teamType        String   // "SCHOOL" or "COLLEGE"
  
  // Role
  role            String   @default("PLAYER") // PLAYER, CAPTAIN, VICE_CAPTAIN
  
  // Status
  isActive        Boolean  @default(true)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?
  
  // Relations
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([studentId, teamId])
  @@index([teamId, isActive])
  @@index([teamType, teamId])
}

// Academic Team Tournament Registration
model AcademicTeamRegistration {
  id              String            @id @default(cuid())
  teamId          String
  teamType        String            // "SCHOOL" or "COLLEGE"
  tournamentId    String
  
  // Registration
  status          RegistrationStatus @default(PENDING)
  registeredAt    DateTime          @default(now())
  registeredBy    String            // OrgAdmin userId
  
  // Payment
  paymentId       String?
  amount          Int               @default(0)
  
  // Result
  finalRank       Int?
  prizeWon        Int               @default(0)
  
  // Relations
  tournament      Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  
  @@unique([teamId, teamType, tournamentId])
  @@index([tournamentId, status])
  @@index([teamType, teamId])
}

// ============================================
// PLAYER EXPERIENCE ENHANCEMENT LAYER (v3.71.0)
// ============================================

// Skill Metrics for Progress Visualization (Radar Chart)
model PlayerSkillMetrics {
  id              String    @id @default(cuid())
  userId          String
  sport           SportType
  
  // Skill dimensions (0-100 scale)
  accuracy        Int       @default(50)     // Shooting accuracy
  consistency     Int       @default(50)     // Performance consistency
  clutch          Int       @default(50)     // Performance under pressure
  endurance       Int       @default(50)     // Long tournament stamina
  strategy        Int       @default(50)     // Game strategy IQ
  teamwork        Int       @default(50)     // Team coordination (doubles)
  
  // Calculated from match history
  matchesAnalyzed Int       @default(0)
  lastCalculated  DateTime  @default(now())
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, sport])
  @@index([sport])
}

// Win Streak Tracking (Enhanced)
model PlayerStreak {
  id              String    @id @default(cuid())
  userId          String
  sport           SportType
  
  // Current streaks
  currentWinStreak    Int       @default(0)
  currentMatchStreak  Int       @default(0)   // Including draws
  currentTournamentStreak Int   @default(0)   // Consecutive tournament wins
  
  // Best streaks (all-time)
  bestWinStreak       Int       @default(0)
  bestMatchStreak     Int       @default(0)
  bestTournamentStreak Int      @default(0)
  
  // Streak details
  streakStartedAt     DateTime?
  lastMatchAt         DateTime?
  
  // Streak type
  streakType          String    @default("WIN")  // WIN, MATCH, TOURNAMENT
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, sport])
