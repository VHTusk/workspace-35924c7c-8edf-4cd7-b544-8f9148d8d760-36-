  displayOrder    Int       @default(0)
  
  // Sharing
  shareCount      Int       @default(0)
  lastSharedAt    DateTime?
  
  // Metadata
  iconUrl         String?
  imageUrl        String?
  
  earnedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, sport])
  @@index([userId, isFeatured])
  @@index([userId, earnedAt])
}

// Quick Team Formation
model QuickTeamRequest {
  id              String    @id @default(cuid())
  userId          String    // Player looking for team
  sport           SportType
  tournamentId    String?   // Specific tournament (optional)
  
  // Preferences
  format          String    // DOUBLES, TEAM
  skillLevelMin   Int?
  skillLevelMax   Int?
  notes           String?
  
  // Status
