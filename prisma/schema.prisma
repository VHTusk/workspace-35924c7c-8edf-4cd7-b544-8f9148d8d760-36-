// ============================================
// DUEL MODE (v3.73.0) - Local Competitive Matches
// ============================================

// Duel Format - Individual (1v1) or Team (2v2, etc.)
enum DuelFormat {
  INDIVIDUAL  // Open Challenge Singles - knockout format
  TEAM        // Open Team Challenge - knockout format
}

// Duel Status
enum DuelStatus {
  DRAFT         // Being created, not yet published
  PENDING_APPROVAL // Submitted, awaiting admin approval
  APPROVED      // Admin approved, ready to publish
  OPEN          // Published, accepting registrations
  FULL          // Maximum participants reached
  LIVE          // Match in progress
  COMPLETED     // Match finished, winner declared
  ESCALATED     // Converted to tournament
  CANCELLED     // Cancelled by host or system
  REJECTED      // Admin rejected the duel
  EXPIRED       // No participants, auto-expired
}

// Duel Approval Status (v3.73.0)
enum DuelApprovalStatus {
  PENDING       // Awaiting admin approval
  AUTO_APPROVED // System auto-approved (all logistics checked)
  APPROVED      // Admin manually approved
  REJECTED      // Admin rejected
}

// Duel Period for City Leaderboards
enum DuelPeriod {
  WEEKLY
  MONTHLY
  ALL_TIME
}

// Venue for Duels (separate from Tournament venues)
model DuelVenue {
  id              String      @id @default(cuid())
  sport           SportType
  
  // Venue Info
  name            String
  address         String
  city            String      // City for geo-locking
  district        String?
  state           String?
  pinCode         String?
  
  // Location
  latitude        Float?
  longitude       Float?
  googleMapsUrl   String?
  
  // Contact
  contactPhone    String?
  contactEmail    String?
  
  // Venue Details
  venueType       String      @default("INDOOR")  // INDOOR, OUTDOOR, HYBRID
  amenities       String?     // JSON array: ["PARKING", "CAFETERIA", "LOCKER"]
  
  // Duel-specific
  isDuelEligible  Boolean     @default(true)
  isActive        Boolean     @default(true)
  
  // Stats
  totalDuelsHosted Int        @default(0)
  
  // Ownership (optional - can be managed by organization or platform)
  managedById     String?     // Organization ID if managed by org
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  slots           DuelVenueSlot[]
  duels           DuelMatch[]
  
  @@index([sport, city, isActive])
  @@index([city, isDuelEligible])
}

// Venue Slot for Duel Booking
model DuelVenueSlot {
  id              String        @id @default(cuid())
  venueId         String
  
  // Slot Details
  date            DateTime      // Date of the slot
  startTime       String        // "09:00" format
  endTime         String        // "10:00" format
  durationMinutes Int           @default(60)
  
  // Slot Status
  status          CourtStatus   @default(AVAILABLE)  // AVAILABLE, OCCUPIED, MAINTENANCE, RESERVED
  
  // Pricing
  slotFee         Int           @default(0)  // Platform fee for booking this slot (in paise)
  
  // Current Booking
  duelMatchId     String?       @unique      // Reference to duel if booked
  
  // Lock for booking in progress
  lockedById      String?       // User ID who is currently booking
  lockedAt        DateTime?
  lockExpiresAt   DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  venue           DuelVenue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  duelMatch       DuelMatch?    @relation("SlotToDuel", fields: [duelMatchId], references: [id])
  
  @@unique([venueId, date, startTime])
  @@index([venueId, date, status])
  @@index([status, date])
}

// The Duel Match (Core)
model DuelMatch {
  id              String        @id @default(cuid())
  sport           SportType
  city            String        // Geo-lock: "Mumbai", "Delhi"
  
  // Host (Creator)
  hostId          String
  host            User          @relation("DuelHost", fields: [hostId], references: [id])
  
  // Format
  format          DuelFormat    @default(INDIVIDUAL)
  
  // Venue & Timing
  venueId         String?
  venue           DuelVenue?    @relation(fields: [venueId], references: [id])
  venueSlot       DuelVenueSlot? @relation("SlotToDuel")
  
  // Fallback venue info (if no venue booking)
  venueName       String?
  venueAddress    String?
  venueGoogleMapsUrl String?
  
  scheduledStart  DateTime
  durationMinutes Int           @default(60)
  
  // Terms (Visible Publicly)
  entryFee        Int           // Entry fee per participant (in paise)
  prizePool       Int           // Total prize pool (in paise), calculated or custom
  platformFeePercent Float      @default(10)  // Platform fee percentage
  matchRules      String?       // JSON: { format: "BEST_OF_3", points: 21, etc. }
  customTerms     String?       // Additional terms as text
  
  // Visibility & Escalation
  isPublic        Boolean       @default(true)
  isEscalatable   Boolean       @default(false)  // Can become tournament
  escalationThreshold Int       @default(4)      // Min participants to escalate
  maxParticipants Int           @default(8)      // Max participants for knockout
  
  // Escalation tracking
  escalatedToTournamentId String?
  
  // Admin Approval (v3.73.0)
  approvalStatus  DuelApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  approvedById    String?       // Admin user ID who approved
  approvalNotes   String?       // Admin notes during approval
  rejectionReason String?       // Reason if rejected
  
  // Status
  status          DuelStatus    @default(DRAFT)
  publishedAt     DateTime?
  
  // Winner
  winnerId        String?
  winner          User?         @relation("DuelWinner", fields: [winnerId], references: [id])
  
  // Result
  finalScore      String?       // JSON: { winner: 21, loser: 15 }
  completedAt     DateTime?
  
  // Cancellation
  cancelledAt     DateTime?
  cancelledById   String?
  cancellationReason String?
  cancellationFee Int?          // Fee deducted if host cancelled with participants
  
  // Auto-expiry
  expiresAt       DateTime?     // Auto-cancel if no participants by this time
  
  // Stats
  viewCount       Int           @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  participants    DuelRegistration[]
  
  @@index([sport, city, status])
  @@index([hostId, status])
  @@index([status, scheduledStart])
  @@index([city, isPublic, status])
}

// Duel Registration (For Open Duels)
model DuelRegistration {
  id              String        @id @default(cuid())
  duelMatchId     String
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  
  // Payment
  paymentStatus   PaymentLedgerStatus @default(INITIATED)
  paymentId       String?       // Razorpay Payment ID
  amount          Int           // Amount paid (in paise)
  
  // Check-in
  checkedIn       Boolean       @default(false)
  checkedInAt     DateTime?
  
  // Team (for TEAM format duels)
  teamId          String?       // If format is TEAM
  teamName        String?
  
  // Result
  isWinner        Boolean       @default(false)
  prizeAmount     Int?          // Prize won (in paise)
  payoutStatus    PayoutStatus?
  payoutAt        DateTime?
  
  // Cancellation/Refund
  refundedAt      DateTime?
  refundAmount    Int?
  refundId        String?
  
  joinedAt        DateTime      @default(now())
  
  duelMatch       DuelMatch     @relation(fields: [duelMatchId], references: [id], onDelete: Cascade)
  
  @@unique([duelMatchId, userId])
  @@index([duelMatchId, paymentStatus])
  @@index([userId, paymentStatus])
}

// City Duel Leaderboard
model CityDuelLeaderboard {
  id              String        @id @default(cuid())
  city            String
  sport           SportType
  period          DuelPeriod
  
  // Period tracking
  startDate       DateTime
  endDate         DateTime?
  
  // Status
  isActive        Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  entries         CityDuelEntry[]
  
  @@unique([city, sport, period, startDate])
  @@index([city, sport, period, isActive])
}

// City Duel Leaderboard Entry
model CityDuelEntry {
  id              String        @id @default(cuid())
  leaderboardId   String
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  
  // Stats
  duelsPlayed     Int           @default(0)
  wins            Int           @default(0)
  losses          Int           @default(0)
  prizeWon        Int           @default(0)  // Total prize won (in paise)
  
  // Rating (separate from global ELO)
  duelRating      Float         @default(1000)  // City duel rating
  
  // Rank
  rank            Int?
  
  updatedAt       DateTime      @updatedAt
  
  leaderboard     CityDuelLeaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  
  @@unique([leaderboardId, userId])
  @@index([leaderboardId, rank])
  @@index([userId])
}

// ============================================
// i18n TRANSLATIONS
// ============================================

// Translation model for i18n support
model Translation {
  id            String    @id @default(cuid())
  key           String    // e.g., "common.welcome"
  category      String    // e.g., "common", "auth", "tournament"
  description   String?   // Description for translators
  
  // Translations in different languages (stored as JSON)
  translations  String    // JSON: { "en": "Welcome", "hi": "स्वागत है", ... }
  
  // Metadata
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  updatedBy     String?   // User ID who last updated
  
  @@unique([key])
  @@index([category])
}

// Language model for supported languages
model SupportedLanguage {
  id            String    @id @default(cuid())
  code          String    @unique  // e.g., "en", "hi", "ta"
  name          String    // e.g., "English", "Hindi", "Tamil"
  nativeName    String?   // e.g., "English", "हिन्दी"
  isActive      Boolean   @default(true)
  isDefault     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([isActive])
}

// ============================================
// PUSH NOTIFICATION DEVICES (v3.81.0)
// ============================================

// Push Device - Stores device tokens for push notifications
model PushDevice {
  id            String    @id @default(cuid())
  userId        String
  token         String    @unique  // FCM device token
  platform      String    // ios, android, web
  
  // Device info
  deviceName    String?   // "iPhone 14 Pro", "Chrome on Windows"
  deviceId      String?   // Unique device identifier
  
  // Status
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime?
  
  // Preferences
  notificationsEnabled Boolean @default(true)
  quietHoursStart      Int?    // 0-23
  quietHoursEnd        Int?    // 0-23
  
  // Metadata
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isActive])
  @@index([token])
  @@index([isActive, lastUsedAt])
}

// ============================================
// IDEMPOTENCY PROTECTION
// ============================================

// Idempotency keys for preventing duplicate operations
// Used for: match score submission, refunds, tournament registration
model IdempotencyKey {
  id            String   @id @default(cuid())
  key           String   @unique
  resourceType  String   // MATCH_RESULT, REFUND, REGISTRATION
  resourceId    String   // ID of the created resource
  requestBody   String   // Hash of request body for verification
  response      String   // JSON of original response
  createdAt     DateTime @default(now())
  expiresAt     DateTime // Auto-expire old keys
  
  @@index([key])
  @@index([resourceType, resourceId])
  @@index([expiresAt])
}

// ============================================
// MATCH EVENT IDEMPOTENCY (Production Scaling v3.80.0)
// Prevents duplicate match result submissions
// Used by: Chess.com, ESL Gaming, Battlefy, FACEIT
// ============================================

model MatchEvent {
  id           String   @id @default(cuid())
  eventId      String   @unique  // Client-provided unique event ID
  matchId      String            // Reference to the match
  eventType    String   // MATCH_STARTED, SCORE_UPDATED, MATCH_COMPLETED, MATCH_VERIFIED
  actorId      String   // User who triggered the event
  actorRole    String   // ADMIN, ORG_ADMIN, TOURNAMENT_DIRECTOR, SYSTEM
  payload      String   // JSON payload of the event
  processedAt  DateTime @default(now())
  
  @@unique([matchId, eventId])  // One event ID per match
  @@index([matchId])
  @@index([eventId])
  @@index([processedAt])
}

// ============================================
// CITY PAGE SYSTEM (v3.82.0)
// Local sports community hubs for each city+sport
// ============================================

// City Status
enum CityStatus {
  ACTIVE        // City page is live and active
  INACTIVE      // City page temporarily disabled
  MERGED        // Merged into another city
}

// Interest Poll Status
enum InterestPollStatus {
  OPEN          // Accepting interest votes
  THRESHOLD_REACHED // Minimum players reached
  TOURNAMENT_CREATED // Tournament created from poll
  EXPIRED       // Poll expired without reaching threshold
  CANCELLED     // Poll cancelled by admin
}

// City Model - Main city page entity
model City {
  id              String      @id @default(cuid())
  cityId          String      @unique  // Format: VH-CITY-DELHI-DARTS
  sport           SportType
  
  // Location
  cityName        String      // "Delhi", "Jaipur"
  state           String      // "Delhi", "Rajasthan"
  country         String      @default("India")
  
  // Stats (cached for performance)
  playerCount     Int         @default(0)
  activePlayersCount Int       @default(0)  // Active in last 30 days
  tournamentCount Int         @default(0)
  matchCount      Int         @default(0)
  duelMatchCount  Int         @default(0)
  
  // Status
  status          CityStatus  @default(ACTIVE)
  isActive        Boolean     @default(true)
  
  // Metadata
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  statsUpdatedAt  DateTime?   // Last time stats were recalculated
  
  // Relations
  interestPolls   TournamentInterestPoll[]
  challengeMatches ChallengeMatch[]
  activityFeed    CityActivityFeedItem[]
  statsHistory    CityStatsSnapshot[]
  venues          Venue[]
  
  @@unique([cityName, state, sport])
  @@index([sport, status])
  @@index([sport, isActive])
  @@index([cityName, sport])
}

// ============================================
// VENUE MODELS (v4.7.0)
// Venue management for Challenge Matches
// ============================================

enum VenueStatus {
  ACTIVE        // Venue is operational
  MAINTENANCE   // Under maintenance
  INACTIVE      // Temporarily closed
}

enum VenueSlotStatus {
  AVAILABLE     // Slot is available for booking
  RESERVED      // Slot is reserved
  BLOCKED       // Blocked by admin
}

model Venue {
  id              String        @id @default(cuid())
  cityId          String
  
  // Venue Info
  name            String        // "Jaipur Sports Complex"
  displayName     String?       // "Jaipur Sports Complex, Vaishali Nagar"
  address         String        // Full address
  locality        String?       // Area/neighborhood
  landmark        String?       // Nearby landmark
  googleMapsUrl   String?       // Google Maps link
  
  // Contact
  contactPhone    String?
  contactEmail    String?
  
  // Sport Configuration
  sport           SportType
  supportedFormats String?      // JSON: ["INDIVIDUAL", "DOUBLES", "TEAM"]
  
  // Play Areas / Courts / Lanes
  playAreas       String?       // JSON: [{id, name, type, capacity}] 
  // e.g., [{"id": "court1", "name": "Court 1", "type": "indoor", "capacity": 2}, ...]
  totalPlayAreas  Int           @default(1)
  
  // Operating Hours
  openingTime     Int           @default(600)   // 6:00 AM in minutes from midnight
  closingTime     Int           @default(1380)  // 11:00 PM in minutes from midnight
  
  // Match Duration Settings (in minutes)
  defaultMatchDuration      Int   @default(30)   // Default match duration
  bufferTimeBetweenMatches  Int   @default(15)   // Buffer between matches
  
  // Amenities
  amenities       String?       // JSON: ["parking", "restrooms", "cafe", "lockers"]
  
  // Status
  status          VenueStatus   @default(ACTIVE)
  isActive        Boolean       @default(true)
  
  // Admin
  managedById     String?       // User ID of venue manager
  verifiedAt      DateTime?     // When venue was verified
  verifiedBy      String?       // Admin who verified
  
  // Metadata
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  city            City          @relation(fields: [cityId], references: [id], onDelete: Cascade)
  slots           VenueSlot[]
  challengeMatches ChallengeMatch[]
  
  @@unique([cityId, name])
  @@index([cityId, isActive])
  @@index([sport, status])
}

// Venue Time Slots
model VenueSlot {
  id              String            @id @default(cuid())
  venueId         String
  
  // Play Area (Court/Lane)
  playAreaId      String?           // Reference to play area from Venue.playAreas
  playAreaName    String?           // "Court 1", "Lane 2", etc.
  
  // Date & Time
  date            DateTime          // Date of the slot (without time)
  startTime       Int               // Start time in minutes from midnight (e.g., 600 = 10:00 AM)
  endTime         Int               // End time in minutes from midnight (e.g., 660 = 11:00 AM)
  
  // Duration (in minutes)
  duration        Int               // Slot duration in minutes
  
  // Capacity
  maxPlayers      Int               @default(2)    // Max players for this slot
  format          TournamentFormat  @default(INDIVIDUAL)
  
  // Status
  status          VenueSlotStatus   @default(AVAILABLE)
  
  // Reservation Info
  reservedById    String?           // ChallengeMatch ID that reserved this slot
  reservedAt      DateTime?
  
  // Pricing (in paise)
  slotPrice       Int               @default(0)    // Base price for this slot
  
  // Metadata
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relations
  venue           Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  
  @@unique([venueId, playAreaId, date, startTime])
  @@index([venueId, date, status])
  @@index([date, status])
}

// City Stats Snapshot - Historical tracking
model CityStatsSnapshot {
  id              String    @id @default(cuid())
  cityId          String
  
  // Stats at snapshot time
  playerCount     Int       @default(0)
  activePlayersCount Int    @default(0)
  tournamentCount Int       @default(0)
  matchCount      Int       @default(0)
  duelMatchCount  Int       @default(0)
  
  // Snapshot metadata
  snapshotDate    DateTime  @default(now())
  snapshotType    String    @default("DAILY") // DAILY, WEEKLY, MONTHLY
  
  city            City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  
  @@unique([cityId, snapshotDate, snapshotType])
  @@index([cityId, snapshotDate])
}

// Tournament Interest Poll - Demand generation before tournament creation
model TournamentInterestPoll {
  id              String            @id @default(cuid())
  cityId          String
  
  // Poll Details
  title           String            // "Jaipur Weekend Darts Cup"
  description     String?
  proposedDate    DateTime?         // Suggested tournament date
  proposedFormat  TournamentFormat  @default(INDIVIDUAL)
  
  // Thresholds
  minPlayers      Int               @default(16)
  maxPlayers      Int               @default(64)
  
  // Interest tracking
  interestedCount Int               @default(0)
  interestedUserIds String?         // JSON array of user IDs who expressed interest
  
  // Status
  status          InterestPollStatus @default(OPEN)
  thresholdReachedAt DateTime?
  
  // Tournament creation
  createdTournamentId String?
  
  // Poll timing
  expiresAt       DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Creator
  createdById     String?           // User who proposed (null = system generated)
  
  city            City              @relation(fields: [cityId], references: [id], onDelete: Cascade)
  
  @@index([cityId, status])
  @@index([status, expiresAt])
}

// Challenge Match - Crowd-funded tournament creation
model ChallengeMatch {
  id              String              @id @default(cuid())
  cityId          String
  sport           SportType
  
  // Match Details
  title           String              // "Weekend Challenge - Jaipur"
  description     String?
  matchDate       DateTime            // Date of the match
  registrationDeadline DateTime       // Last date to join
  
  // Venue Information (normalized reference + display fields)
  venueId         String?             // Reference to Venue model
  venueName       String              // Display name (cached for quick display)
  venueAddress    String?             // Full address
  venueMapsUrl    String?             // Google Maps link
  
  // Scheduling
  startTime       Int                 // Start time in minutes from midnight (e.g., 600 = 10:00 AM)
  endTime         Int?                // End time in minutes from midnight
  estimatedDuration Int               // Estimated duration in minutes
  
  // Format & Players
  format          TournamentFormat    @default(INDIVIDUAL)
  matchType       String              @default("1v1")  // "1v1", "2v2", "TEAM"
  playerSlots     Int                 @default(8)    // Total participant slots
  minPlayers      Int                 @default(8)    // Minimum to confirm
  maxPlayers      Int                 @default(32)   // Maximum capacity
  
  // Rules
  matchFormat     String?             @default("BEST_OF_1")  // BEST_OF_1, BEST_OF_3, BEST_OF_5
  scoreTarget     Int?                // Points/score target if applicable
  rules           String?             // Additional rules notes
  tieBreakRule    String?             // Tie-break/dispute resolution
  
  // Fee & Prize (Financial Calculations)
  entryFee        Int                 @default(100000)  // In paise (₹1000 recommended)
  adminFeePercentage Int              @default(30)     // 30% admin fee
  prizePoolPercentage Int             @default(70)     // 70% to prize pool
  
  // Calculated Financial Fields (server-computed)
  totalCollection Int                 @default(0)      // Total entry fees collected
  adminFee        Int                 @default(0)      // Platform fee amount
  prizePool       Int                 @default(0)      // Net prize pool
  firstPrizeAmount Int                @default(0)      // 1st prize amount
  secondPrizeAmount Int               @default(0)      // 2nd prize amount
  
  // Base prize pool from sponsors
  basePrizePool   Int                 @default(0)
  
  // Participant Tracking
  joinedCount     Int                 @default(0)
  joinedUserIds   String?             // JSON array: [{userId, joinedAt, paymentStatus}]
  confirmedCount  Int                 @default(0)      // Paid participants
  paidUserIds     String?             // JSON array of user IDs who paid
  
  // Sponsor Information
  sponsorName     String?
  sponsorLogo     String?             // URL to sponsor logo
  sponsorAmount   Int                 @default(0)      // Sponsorship amount in paise
  sponsorMessage  String?
  
  // Visibility
  visibility      String              @default("PUBLIC")  // PUBLIC, DISTRICT_ONLY, INVITE_ONLY
  skillLevel      String?             @default("OPEN")    // BEGINNER, INTERMEDIATE, ADVANCED, OPEN
  
  // Status
  status          ChallengeMatchStatus @default(OPEN)
  thresholdReachedAt DateTime?
  confirmedAt     DateTime?           // When match was confirmed
  cancelledAt     DateTime?
  cancelReason    String?
  
  // Tournament Creation
  createdTournamentId String?
  
  // Creator
  createdById     String
  
  // Timestamps
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  city            City                @relation(fields: [cityId], references: [id], onDelete: Cascade)
  venue           Venue?              @relation(fields: [venueId], references: [id], onDelete: SetNull)
  
  @@index([cityId, status])
  @@index([status, matchDate])
  @@index([sport, status])
  @@index([venueId, matchDate])
}

enum ChallengeMatchStatus {
  OPEN              // Accepting joins
  THRESHOLD_REACHED // Min players joined - requesting payment
  PAYMENT_PENDING   // Collecting payments
  CONFIRMED         // Match confirmed, all paid
  IN_PROGRESS       // Match is happening
  COMPLETED         // Match finished
  CANCELLED         // Cancelled due to insufficient players or other reason
  EXPIRED           // Registration deadline passed
}

// City Activity Feed Item - Duel results and local activity
model CityActivityFeedItem {
  id              String    @id @default(cuid())
  cityId          String
  sport           SportType
  
  // Activity Type
  activityType    String    // DUEL_RESULT, TOURNAMENT_ANNOUNCEMENT, NEW_PLAYER, ACHIEVEMENT
  
  // Content
  title           String    // "Rohit defeated Sameer (3-1)"
  description     String?
  metadata        String?   // JSON: { playerA, playerB, score, format }
  
  // Related entities
  duelMatchId     String?
  tournamentId    String?
  userId          String?   // For player achievements
  
  // Display
  isFeatured      Boolean   @default(false)
  viewCount       Int       @default(0)
  
  // Timing
  activityAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  city            City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  
  @@index([cityId, activityAt])
  @@index([cityId, activityType])
  @@index([activityType, activityAt])
}

// City Leaderboard Cache - Pre-computed rankings for performance
model CityLeaderboardCache {
  id              String    @id @default(cuid())
  cityId          String
  sport           SportType
  
  // Player info
  userId          String
  playerName      String
  playerRating    Float
  matchesPlayed   Int
  wins            Int
  losses          Int
  winPercentage   Float
  
  // Rank
  rank            Int
  
  // Cache metadata
  calculatedAt    DateTime  @default(now())
  period          String    @default("ALL_TIME") // WEEKLY, MONTHLY, ALL_TIME
  
  @@unique([cityId, sport, userId, period])
  @@index([cityId, sport, period, rank])
}

// ============================================
// RETENTION & INTELLIGENCE LAYER (v3.51.0)
// Self-healing, feedback, re-engagement, notifications
// ============================================

// Healing Log - Tracks self-healing check results
model HealingLog {
  id          String   @id @default(cuid())
  sport       SportType?
  checkName   String   // ORPHANED_BRACKET_MATCHES, MISSING_ELO_RATINGS, etc.
  issuesFound Int      @default(0)
  issuesFixed Int      @default(0)
  details     String?  // JSON with details of what was found/fixed
  dryRun      Boolean  @default(false)
  ranAt       DateTime @default(now())
  
  @@index([checkName, ranAt])
  @@index([ranAt])
}

// Re-engagement Log - Track player re-engagement attempts
model ReengagementLog {
  id            String   @id @default(cuid())
  userId        String
  sport         SportType
  
  // Tier: MILD (30-59 days), MODERATE (60-89 days), SEVERE (90+ days)
  inactivityTier String  // MILD, MODERATE, SEVERE
  daysInactive  Int
  
  // Engagement attempt
  channel       String   // EMAIL, PUSH, WHATSAPP
  sentAt        DateTime @default(now())
  
  // Response tracking
  responded     Boolean  @default(false)
  respondedAt   DateTime?
  
  // Incentive offered
  incentiveType String?  // CREDITS, DISCOUNT, FREE_ENTRY, REFERRAL_BONUS
  incentiveId   String?  // Reference to PlayerIncentive
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, sentAt])
  @@index([sport, sentAt])
}

// Player Incentive - Store incentive offers for re-engagement
model PlayerIncentive {
  id              String   @id @default(cuid())
  userId          String
  sport           SportType
  
  // Incentive details
  type            String   // CREDITS, DISCOUNT, FREE_ENTRY, REFERRAL_BONUS
  value           Float    // Credit amount, discount percentage, etc.
  description     String?
  
  // Validity
  expiresAt       DateTime
  
  // Status
  claimed         Boolean  @default(false)
  claimedAt       DateTime?
  
  // Related re-engagement
  reengagementLogId String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, expiresAt])
  @@index([sport, expiresAt, claimed])
}

// Feedback Request - Track when feedback is requested
model FeedbackRequest {
  id            String   @id @default(cuid())
  userId        String
  sport         SportType
  
  // Trigger
  triggerType   String   // TOURNAMENT_COMPLETION, MATCH_COMPLETION, PLATFORM_MILESTONE, NPS_SURVEY
  triggeredAt   DateTime @default(now())
  
  // Related entities
  tournamentId  String?
  matchId       String?
  
  // Feedback window
  windowEndsAt  DateTime  // When feedback window closes
  
  // Status
  responded     Boolean   @default(false)
  respondedAt   DateTime?
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, responded])
  @@index([triggerType, triggeredAt])
}

// Feedback - Store feedback submissions
model Feedback {
  id              String   @id @default(cuid())
  userId          String
  sport           SportType
  
  // Feedback type
  feedbackType    String   // TOURNAMENT, MATCH, PLATFORM, NPS
  
  // Ratings
  rating          Int?     // 1-5 stars
  npsScore        Int?     // 0-10 NPS score
  
  // Categories
  categories      String?  // JSON array: ["VENUE", "OFFICIATING", "SCHEDULING"]
  
  // Written feedback
  comment         String?
  
  // Would recommend
  wouldRecommend  Boolean?
  
  // Related entity
  tournamentId    String?
  matchId         String?
  feedbackRequestId String?
  
  // Metadata
  submittedAt     DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, submittedAt])
  @@index([sport, feedbackType])
  @@index([feedbackType, submittedAt])
}

// System Health - Health check logs
model SystemHealth {
  id            String    @id @default(cuid())
  service       String    // DATABASE, CACHE, RAZORPAY, EMAIL, PUSH, CRON
  checkType     String    // QUERY_TIME, RESPONSE_TIME, LATENCY, SEND_RATE, EXECUTION
  
  // Result
  status        String    // HEALTHY, DEGRADED, UNHEALTHY
  value         Float?    // Measurement value (ms, percentage, etc.)
  threshold     Float?    // Threshold that was checked against
  
  // Details
  message       String?
  metadata      String?   // JSON
  
  checkedAt     DateTime  @default(now())
  
  @@index([service, checkedAt])
  @@index([status, checkedAt])
}

// System Alert - Alert management
model SystemAlert {
  id            String    @id @default(cuid())
  service       String
  severity      String    // INFO, WARNING, ERROR, CRITICAL
  
  // Alert details
  title         String
  message       String
  metadata      String?   // JSON
  
  // Status
  status        String    // ACTIVE, ACKNOWLEDGED, RESOLVED
  acknowledgedAt DateTime?
  resolvedAt    DateTime?
  acknowledgedBy String?
  
  // Notification
  notified      Boolean   @default(false)
  notifiedAt    DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([severity, status])
  @@index([service, status])
  @@index([createdAt])
}

// Recovery Log - Recovery action logs
model RecoveryLog {
  id              String   @id @default(cuid())
  service         String
  
  // Recovery type
  recoveryType    String   // JOB_RETRY, REFUND_REQUEUE, STALLED_TOURNAMENT, CIRCUIT_BREAKER, DB_LOCK
  
  // Trigger
  triggerReason   String
  triggerDetails  String?  // JSON
  
  // Action taken
  actionTaken     String
  actionDetails   String?  // JSON
  
  // Result
  success         Boolean
  errorMessage    String?
  
  recoveredAt     DateTime @default(now())
  
  @@index([service, recoveredAt])
  @@index([recoveryType, success])
}

// Scheduled Notification - Queued notifications for delivery
model ScheduledNotification {
  id              String   @id @default(cuid())
  userId          String?
  orgId           String?
  sport           SportType?
  
  // Notification content
  type            String   // MATCH_REMINDER, TOURNAMENT_REMINDER, REENGAGEMENT, etc.
  title           String
  message         String
  link            String?
  
  // Channels
  channels        String   // JSON array: ["EMAIL", "PUSH", "WHATSAPP", "IN_APP"]
  preferredChannel String? // Selected optimal channel
  
  // Scheduling
  scheduledFor    DateTime
  sentAt          DateTime?
  
  // Status
  status          String   // PENDING, SENT, FAILED
  failureReason   String?
  
  // Retry
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)
  nextRetryAt     DateTime?
  
  // Metadata
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
  
  // Relations (optional because userId can be null for org notifications)
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([scheduledFor, status])
  @@index([userId, status])
  @@index([status, retryCount, nextRetryAt])
}

// Batched Notification - Grouped low-priority notifications
model BatchedNotification {
  id              String   @id @default(cuid())
  userId          String
  sport           SportType
  
  // Batch details
  notificationIds String   // JSON array of ScheduledNotification IDs
  notificationCount Int
  
  // Content (merged)
  summary         String   // "You have 5 new notifications"
  details         String?  // JSON with notification details
  
  // Scheduling
  batchStartAt   DateTime  // When first notification was added to batch
  batchEndAt     DateTime? // When batch was finalized
  
  // Delivery
  scheduledFor    DateTime? // When digest should be sent
  sentAt          DateTime?
  channel         String?   // Final delivery channel
  
  // Status
  status          String    // BATCHING, READY, SENT, FAILED
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, status])
  @@index([status, batchStartAt])
}

// ============================================
// RELATIONS NOTE
// Relations for Retention models have been added to the User model above.

// ============================================
// ABUSE DETECTION SYSTEM (v4.4.0)
// Detect and prevent suspicious patterns
// ============================================

// Device Fingerprint - Track unique devices across accounts
model DeviceFingerprint {
  id            String    @id @default(cuid())
  fingerprint   String    @unique  // Hash of device characteristics
  userId        String
  
  // Device characteristics (stored for analysis)
  userAgent     String?   // Browser user agent
  screenRes     String?   // Screen resolution (e.g., "1920x1080")
  timezone      String?   // Browser timezone
  language      String?   // Browser language
  platform      String?   // OS platform (Windows, Mac, Linux, Android, iOS)
  
  // Network info
  ipAddress     String?   // Last known IP
  country       String?   // Country from IP
  city          String?   // City from IP
  
  // Tracking
  firstSeenAt   DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  loginCount    Int       @default(0)
  
  // Risk score for this device (0-100)
  riskScore     Int       @default(0)
  isBlocked     Boolean   @default(false)
  blockedReason String?
  blockedAt     DateTime?
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([fingerprint])
  @@index([userId])
  @@index([isBlocked])
  @@index([riskScore])
}

// Abuse Event - Record of detected abuse patterns
model AbuseEvent {
  id              String        @id @default(cuid())
  pattern         AbusePattern
  severity        AbuseSeverity @default(LOW)
  
  // Who triggered the event
  userId          String?       // Can be null for unauthenticated attempts
  deviceId        String?       // Device fingerprint ID
  
  // Detection details
  detectedAt      DateTime      @default(now())
  ipAddress       String?
  userAgent       String?
  
  // Evidence
  metadata        String?       // JSON with detection details
  
  // Resolution
  status          String        @default("PENDING") // PENDING, REVIEWED, RESOLVED, FALSE_POSITIVE
  reviewedAt      DateTime?
  reviewedBy      String?       // Admin user ID
  resolution      String?       // Resolution notes
  
  // Action taken
  actionTaken     String?       // e.g., "account_locked", "device_blocked", "warning_sent"
  actionDetails   String?       // JSON with action details
  
  // Relations
  user            User?         @relation("AbuseEventUser", fields: [userId], references: [id], onDelete: SetNull)
  reviewer        User?         @relation("AbuseEventReporter", fields: [reviewedBy], references: [id], onDelete: SetNull)
  
  @@index([pattern])
  @@index([severity])
  @@index([status])
  @@index([userId])
  @@index([deviceId])
  @@index([detectedAt])
}

// ============================================
// APPEALS SYSTEM (v4.5.0)
// Appeal moderation decisions
// ============================================

// Appeal Type - What type of decision is being appealed
enum AppealType {
  BAN               // Account ban appeal
  WARNING           // Warning appeal
  SUSPENSION        // Tournament suspension appeal
  POINT_DEDUCTION   // Point deduction appeal
  CONTENT_REMOVAL   // Content removal appeal
  OTHER             // Other moderation decisions
}

// Appeal Status
enum AppealStatus {
  PENDING           // Waiting for review
  UNDER_REVIEW      // Being reviewed by admin
  APPROVED          // Appeal approved, action reversed
  REJECTED          // Appeal rejected
  ESCALATED         // Escalated to higher admin
}

// Appeal Model
model Appeal {
  id              String        @id @default(cuid())
  userId          String
  type            AppealType
  status          AppealStatus  @default(PENDING)
  
  // Related entity (optional reference)
  relatedId       String?       // Tournament ID, Match ID, or other reference
  
  // Appeal content
  reason          String        // User explanation for appeal
  evidence        String?       // Additional evidence provided
  
  // Tracking
  submittedAt     DateTime      @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?       // Admin user ID who reviewed
  
  // Resolution
  resolution      String?       // Resolution notes
  resolutionType  String?       // "APPROVED", "REJECTED", "PARTIAL"
  
  // Admin notes (internal)
  adminNotes      String?
  
  // Priority (for admin queue)
  priority        Int           @default(0)  // Higher = more urgent
  
  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer        User?         @relation("AppealReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  
  @@index([userId, status])
  @@index([status, submittedAt])
  @@index([type])
  @@index([priority])
}

// ============================================
// COUPON SYSTEM (v4.6.0)
// Promo codes for discounts on subscriptions and tournament entries
// ============================================

// Discount Type for Coupons
enum DiscountType {
  PERCENTAGE    // Percentage discount (e.g., 20% off)
  FIXED         // Fixed amount discount (e.g., ₹100 off)
  FREE_ENTRY    // 100% discount - free entry
}

// Coupon - Promo code definition
model Coupon {
  id                String        @id @default(cuid())
  couponCode        String        @unique
  discountType      DiscountType
  discountValue     Int          // Percentage (e.g., 20) or fixed amount in paise
  maxDiscountLimit  Int?         // Maximum discount in paise (for percentage discounts)
  applicableProduct String       // TOURNAMENT, MEMBERSHIP, ALL
  expiryDate        DateTime?
  usageLimit        Int?         // Total usage limit
  usageCount        Int          @default(0)
  usagePerUserLimit Int          @default(1)
  minOrderValue     Int?         // Minimum order value in paise
  status            String       @default("ACTIVE") // ACTIVE, INACTIVE
  tournamentId      String?      // For tournament-specific coupons
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  tournament        Tournament?  @relation(fields: [tournamentId], references: [id])
  usages            CouponUsage[]

  @@index([couponCode])
  @@index([status])
  @@index([expiryDate])
  @@index([tournamentId])
}

// Coupon Usage - Track coupon usage per user
model CouponUsage {
  id              String   @id @default(cuid())
  couponId        String
  userId          String
  orderId         String?
  discountApplied Int      // Discount amount in paise
  createdAt       DateTime @default(now())
  
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// FILE UPLOAD SYSTEM (v4.18.0)
// Secure file upload tracking and ownership
// ============================================

model UploadedFile {
  id              String    @id @default(cuid())
  userId          String
  
  // File metadata
  purpose         String    // profilePhoto, idDocument, tournamentGallery, contractPdf, orgLogo, general
  filename        String    // Sanitized filename
  originalFilename String   // Original user-provided filename
  mimeType        String    // Detected MIME type
  size            Int       // File size in bytes
  path            String    // Relative path within upload directory
  url             String    // Public URL to access file
  
  // Security tracking
  virusScanned    Boolean   @default(false)
  virusScanResult String?   // 'clean', 'infected', 'error'
  
  // Access control
  isPublic        Boolean   @default(false)
  accessCount     Int       @default(0)
  lastAccessedAt  DateTime?
  
  // Deletion tracking
  deletedAt       DateTime?
  deletionReason  String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([purpose])
  @@index([createdAt])
  @@index([deletedAt])
}


// ============================================
// CORPORATE ARCHITECTURE v4.0 - Organization-Level System
// ============================================

// Organization Member Roles
enum OrgMemberRole {
  OWNER     // Full access, billing, can delete org
  ADMIN     // Manage sports modules, create tournaments, manage employees/squads
  MANAGER   // Limited operational access, tournaments/squads only
  VIEWER    // Read-only access
}

// Organization Member Status
enum OrgMemberStatus {
  ACTIVE    // Active member with access
  INVITED   // Invited but not yet accepted
  DISABLED  // Access revoked
  PENDING   // Pending verification
}

// Sport Subscription Status
enum SportSubscriptionStatus {
  ACTIVE    // Currently active subscription
  TRIAL     // In trial period
  EXPIRED   // Subscription expired
  INACTIVE  // Not activated
  SUSPENDED // Suspended due to payment issues
}

// Sport Plan Type
enum SportPlanType {
  ROOKIE      // Basic plan
  PRO         // Professional plan
  ENTERPRISE  // Enterprise plan
}

// Sport Player Status
enum SportPlayerStatus {
  ACTIVE      // Active player
  BENCH       // On bench
  INACTIVE    // Not currently playing
  INJURED     // Injured
}

// Organization Membership - Multi-user support
model OrganizationMembership {
  id          String          @id @default(cuid())
  orgId       String
  userId      String
  role        OrgMemberRole   @default(VIEWER)
  status      OrgMemberStatus @default(INVITED)
  
  // Invitation tracking
  invitedBy   String?         // User ID who invited
  invitedAt   DateTime?
  acceptedAt  DateTime?
  
  // Access control
  lastLoginAt DateTime?
  
  // Audit
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([orgId, userId])
  @@index([userId, status])
  @@index([orgId, role])
}

// Organization Sport - Per-sport activation
model OrganizationSport {
  id            String                  @id @default(cuid())
  orgId         String
  sport         SportType
  
  // Subscription
  status        SportSubscriptionStatus @default(INACTIVE)
  planType      SportPlanType           @default(ROOKIE)
  
  // Dates
  activatedAt   DateTime?
  expiresAt     DateTime?
  trialEndsAt   DateTime?
  
  // Billing reference
  stripeSubscriptionId String?
  stripePriceId       String?
  
  // Audit
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  
  // Relations
  organization  Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entitlement   OrganizationSportEntitlement?
  
  @@unique([orgId, sport])
  @@index([orgId, status])
  @@index([expiresAt])
}

// Organization Sport Entitlement - Feature flags per sport
model OrganizationSportEntitlement {
  id                      String  @id @default(cuid())
  orgSportId              String  @unique
  
  // Feature toggles
  canManageIntra          Boolean @default(true)
  canManageInter          Boolean @default(true)
  canCreateTournaments    Boolean @default(true)
  canCreateSquads         Boolean @default(true)
  canAccessAnalytics      Boolean @default(true)
  canManageEmployees      Boolean @default(true)
  canViewLeaderboard      Boolean @default(true)
  
  // Limits
  maxPlayers              Int     @default(50)
  maxTournaments          Int     @default(10)
  maxSquads               Int     @default(5)
  maxEmployees            Int     @default(100)
  
  // Audit
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  // Relations
  orgSport                OrganizationSport @relation(fields: [orgSportId], references: [id], onDelete: Cascade)
}

// Organization Audit Log
model OrgAuditLog {
  id            String    @id @default(cuid())
  orgId         String
  userId        String?
  
  // Action details
  action        String    // CREATE_TOURNAMENT, UPDATE_SQUAD, etc.
  entityType    String    // TOURNAMENT, SQUAD, EMPLOYEE, etc.
  entityId      String?
  
  // Change details
  oldValues     String?   // JSON
  newValues     String?   // JSON
  
  // Context
  ipAddress     String?
  userAgent     String?
  
  timestamp     DateTime  @default(now())
  
  // Relations
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id])
  
  @@index([orgId, timestamp])
  @@index([entityType, entityId])
  @@index([userId])
}

// Sport Player - Sport-specific player mapping (links Employee to sport)
model SportPlayer {
  id            String            @id @default(cuid())
  orgId         String
  sport         SportType
  employeeId    String
  
  // Player status in this sport
  status        SportPlayerStatus @default(ACTIVE)
  skillLevel    Int?              // 1-10 skill rating
  
  // Sport-specific stats
  matchesPlayed Int               @default(0)
  wins          Int               @default(0)
  losses        Int               @default(0)
  points        Int               @default(0)
  
  // Audit
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  
  // Relations
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@unique([orgId, sport, employeeId])
  @@index([orgId, sport, status])
}
