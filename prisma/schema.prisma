  secret    String
  enabled   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MfaRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
}

model Wallet {
  id        String    @id @default(cuid())
  userId    String    @unique
  sport     SportType
  balance   Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sport])
}

// Tournament Reminder tracking (persists across server restarts)
model TournamentReminder {
  id            String    @id @default(cuid())
  tournamentId  String
  userId        String
  hoursBefore   Int       // 48, 24, or 2 hours before tournament
  sentAt        DateTime  @default(now())
  createdAt     DateTime  @default(now())

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId, hoursBefore])
  @@index([tournamentId])
  @@index([userId])
}

// Match Reminder tracking (v3.45.0) - Per-match reminders
model MatchReminder {
  id            String    @id @default(cuid())
  matchId       String
  userId        String
  minutesBefore Int       // 120 (2h), 30, 5 minutes before match
  sentAt        DateTime  @default(now())
  createdAt     DateTime  @default(now())

  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId, minutesBefore])
  @@index([matchId])
  @@index([userId])
  @@index([sentAt])
}

// Autopilot Action Log (v3.45.0) - Track all autopilot actions for audit
model AutopilotLog {
  id              String    @id @default(cuid())
  tournamentId    String
  action          String    // REGISTRATION_CLOSED, BRACKET_GENERATED, TOURNAMENT_STARTED, WINNER_ADVANCED, WAITLIST_PROMOTED
  status          String    // SUCCESS, FAILED, SKIPPED
  details         String?   // JSON details of the action
  errorMessage    String?
  executedAt      DateTime  @default(now())

  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, executedAt])
  @@index([action, status])
}

// ============================================
// ADMIN HIERARCHY MODELS (v4.15.0)
// Simplified 5-level hierarchy: SUPER_ADMIN > SPORT_ADMIN > STATE_ADMIN > DISTRICT_ADMIN > TOURNAMENT_DIRECTOR
// ============================================

// Core Admin Assignment Model - Links user to role + sport + geography
model AdminAssignment {
  id             String      @id @default(cuid())
  userId         String
  sport          SportType?  // null = all sports (Super Admin only)
  adminRole      AdminRole

  // Geographic scope (one of these is set based on role)
  stateCode      String?     // STATE_ADMIN scope ('RJ', 'MH', etc.)
  districtName   String?     // DISTRICT_ADMIN scope ('Jaipur', 'Mumbai', etc.)

  // Activation state (Enable/Disable Governance)
  isActive       Boolean     @default(true)
  deactivatedAt  DateTime?
  deactivatedBy  String?     // Admin who deactivated
  deactivationReason String?

  // Assignment metadata
  assignedById   String      // Who gave this role
  assignedAt     DateTime    @default(now())
  expiresAt      DateTime?   // For temporary assignments (event-day volunteers)

  // Performance metrics
  trustLevel     Int         @default(0)  // 0=new, 1=trusted, 2=senior
  actionsCount   Int         @default(0)  // Number of actions taken
  escalationsCount Int       @default(0)  // Number of escalations caused

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  user           User        @relation(fields: [userId], references: [id])
  permissions    AdminPermissions?
  escalations    AdminEscalation[]
  auditLogs      AdminAuditLog[]
  availabilities AdminAvailability[]

  @@unique([userId, sport, adminRole, stateCode, districtName])
  @@index([adminRole, isActive])
  @@index([sport, adminRole])
  @@index([stateCode, districtName])
}

// Granular Permissions - Per-admin configurable permissions
model AdminPermissions {
  id                      String   @id @default(cuid())
  assignmentId            String   @unique

  // Tournament Management
  canCreateTournament     Boolean  @default(false)
  canApproveTournament    Boolean  @default(false)
  canPublishTournament    Boolean  @default(false)
  canStartTournament      Boolean  @default(false)
  canPauseTournament      Boolean  @default(false)
  canCancelTournament     Boolean  @default(false)
  canEditTournament       Boolean  @default(false)

  // Match & Bracket
  canGenerateBracket      Boolean  @default(false)
  canScoreMatches         Boolean  @default(false)
  canRollbackMatch        Boolean  @default(false)
  canOverrideResult       Boolean  @default(false)

  // Player Management
  canViewPlayers          Boolean  @default(true)
  canEditPlayer           Boolean  @default(false)
  canBanPlayer            Boolean  @default(false)
  canAdjustElo            Boolean  @default(false)
  maxEloAdjustment        Int      @default(0)  // Maximum ELO points can adjust

  // Financial
  canViewRevenue          Boolean  @default(false)
  canProcessRefund        Boolean  @default(false)
  canProcessPayout        Boolean  @default(false)

  // Dispute Resolution
  canViewDisputes         Boolean  @default(true)
  canResolveDisputes      Boolean  @default(false)

  // Organization
  canApproveOrgs          Boolean  @default(false)
  canSuspendOrgs          Boolean  @default(false)

  // Admin Management
  canAssignAdmins         Boolean  @default(false)
  canAssignDirectors      Boolean  @default(false)

  // System
  canViewAuditLogs        Boolean  @default(false)
  canManageFeatureFlags   Boolean  @default(false)
  canViewAnalytics        Boolean  @default(false)
  canManageSportRules     Boolean  @default(false)
  canAccessHealthDashboard Boolean @default(false)
  canManageSectors        Boolean  @default(false)  // Create/edit zones

  // Dangerous (Super Admin only)
  canEditCompletedMatch   Boolean  @default(false)
  canDeleteTournament     Boolean  @default(false)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  assignment              AdminAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

// Escalation Chain - Track escalated actions
model AdminEscalation {
  id              String      @id @default(cuid())
  type            String      // DISPUTE, BAN_REQUEST, REFUND, CANCEL, ELO_ADJUSTMENT
  requestedById   String      // Admin who requested
  requestedAction String      // What they want to do
  resourceType    String      // TOURNAMENT, PLAYER, DISPUTE, MATCH
  resourceId      String      // ID of the resource

  currentLevel    AdminRole   // Current escalation level
  assignedToId    String?     // Admin assigned to handle
  status          String      @default("PENDING") // PENDING, ASSIGNED, RESOLVED, AUTO_ESCALATED

  escalationChain String      // JSON: [{role, userId, time, action}]
  autoEscalateAt  DateTime?   // When to auto-escalate if no response

  resolution      String?     // How it was resolved
  resolvedById    String?     // Who resolved it
  resolvedAt      DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  assignment      AdminAssignment @relation(fields: [requestedById], references: [id])

  @@index([type, status])
  @@index([currentLevel, status])
  @@index([autoEscalateAt])
}

// Admin Audit Log - Track all admin actions including enable/disable
model AdminAuditLog {
  id              String   @id @default(cuid())
  assignmentId    String   // The admin assignment affected

  action          String   // ENABLE, DISABLE, PERMISSION_CHANGE, ASSIGN, REVOKE, ESCALATE
  targetType      String?  // What was affected (optional)
  targetId        String?  // ID of what was affected

  oldValue        String?  // JSON of previous state
  newValue        String?  // JSON of new state

  reason          String?  // Why the change was made
  ipAddress       String?

  actedById       String   // Who performed this action
  actedAt         DateTime @default(now())

  assignment      AdminAssignment @relation(fields: [assignmentId], references: [id])

  @@index([assignmentId, actedAt])
  @@index([action, actedAt])
}

// Admin Availability Calendar - Track admin availability for tournament assignments
model AdminAvailability {
  id          String   @id @default(cuid())
  adminId     String
  admin       AdminAssignment @relation(fields: [adminId], references: [id])
  date        DateTime
  isAvailable Boolean @default(true)
  notes       String?
  isRecurring Boolean @default(false)
  recurrencePattern String? // e.g., "weekly", "biweekly"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([adminId, date])
  @@index([adminId, date])
  @@index([adminId, isRecurring])
}

// Admin Performance Metrics - Track admin activity for trust scoring
model AdminMetrics {
  id                  String   @id @default(cuid())
  adminId             String   @unique
  userId              String   @unique // Link to User model

  // Action counts
  tournamentsCreated  Int      @default(0)
  tournamentsApproved Int      @default(0)
  matchesScored       Int      @default(0)
  disputesResolved    Int      @default(0)
  refundsProcessed    Int      @default(0)
  adminsAssigned      Int      @default(0)

  // Response times (in minutes)
  avgResponseTime     Float    @default(0)
  escalationCount     Int      @default(0)  // Times escalated upward
  escalationsHandled  Int      @default(0)  // Escalations handled from below

  // Trust scoring
  trustScore          Int      @default(0)  // 0-100
  trustLevel          Int      @default(0)  // 0=new, 1=trusted, 2=senior
  lastTrustReview     DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id])

  @@index([trustScore])
}

// ============================================
// VENUE FLOW MODELS (v3.47.0)
// ============================================

// Tournament Court/Board Management
model Court {
  id              String      @id @default(cuid())
  tournamentId    String
  name            String      // 'Court 1', 'Board A', 'Lane 1'
  code            String?     // Short code: 'C1', 'B1'
  
  // Status
  status          CourtStatus @default(AVAILABLE)
  
  // Current assignment
  currentMatchId  String?
  assignedAt      DateTime?
  
  // Capacity/type
  capacity        Int         @default(2)  // Players per match
  courtType       String?     // 'INDOOR', 'OUTDOOR', 'PROFESSIONAL', 'PRACTICE'
  isPriority      Boolean     @default(false)  // Priority courts for important matches
  
  // Usage tracking
  matchesHosted   Int         @default(0)
  totalOccupiedMinutes Int    @default(0)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  tournament      Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  checkIns        MatchCheckIn[]
  assignments     CourtAssignment[]
  flowLogs        VenueFlowLog[]
  
  @@unique([tournamentId, name])
  @@index([tournamentId, status])
  @@index([status, isPriority])
}

// Player Match Check-In
model MatchCheckIn {
  id              String        @id @default(cuid())
  matchId         String
  playerId        String
  courtId         String?       // If checked in at specific court
  
  // Check-in status
  status          CheckInStatus @default(NOT_CHECKED_IN)
  checkedInAt     DateTime?
  
  // Grace period tracking
  gracePeriodEnds DateTime?
  extensionCount  Int           @default(0)
  extendedById    String?       // Admin who extended
  
  // No-show tracking
  noShowDetectedAt DateTime?
  noShowConfirmedAt DateTime?
  noShowConfirmedBy String?
  
  // Source
  source          String        @default("PLAYER") // PLAYER, ADMIN, DIRECTOR, SYSTEM
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  match           Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player          User          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  court           Court?        @relation(fields: [courtId], references: [id])
  
  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([status])
  @@index([gracePeriodEnds])
}

// Venue Flow Configuration per Tournament
model VenueFlowConfig {
  id                    String    @id @default(cuid())
  tournamentId          String    @unique
  
  // Check-in settings
  checkInEnabled        Boolean   @default(true)
  checkInOpensMinutes   Int       @default(30)  // Minutes before match to open check-in
  
  // No-show settings
  noShowGraceMinutes    Int       @default(15)  // Grace period after match time
  autoNoShowEnabled     Boolean   @default(false) // Auto-detect no-shows
  requireDirectorConfirm Boolean  @default(true) // Require director confirmation for no-show
  
  // Court assignment
  autoCourtAssign       Boolean   @default(true)  // Auto-assign courts
  priorityCourtsForSeeds Int?     // Use priority courts for top N seeds
  
  // Dynamic scheduling
  dynamicScheduling     Boolean   @default(true)
  queueBufferMinutes    Int       @default(5)  // Buffer between matches
  maxQueueSize          Int       @default(10) // Max matches in queue
  
  // Health monitoring
  healthCheckInterval   Int       @default(60)  // Seconds between health checks
  idleCourtAlertMinutes Int      @default(5)   // Alert if court idle for N minutes
  
  // Notifications
  notifyPlayerReady     Boolean   @default(true)  // Notify when opponent ready
  notifyCourtAssigned   Boolean   @default(true)
  notifyNoShow          Boolean   @default(true)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  tournament            Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

// Court Assignment History
model CourtAssignment {
  id              String    @id @default(cuid())
  courtId         String
  matchId         String
  
  // Assignment details
  assignedAt      DateTime  @default(now())
  assignedBy      String?   // System or admin ID
  isAutoAssigned  Boolean   @default(true)
  
  // Match lifecycle
  matchStartedAt  DateTime?
  matchEndedAt    DateTime?
  
  // Release
  releasedAt      DateTime?
  releasedBy      String?
  releaseReason   String?
  
  court           Court     @relation(fields: [courtId], references: [id], onDelete: Cascade)
  match           Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  @@index([courtId, assignedAt])
  @@index([matchId])
  @@index([releasedAt])
}

// Venue Flow Audit Log
model VenueFlowLog {
  id              String            @id @default(cuid())
  tournamentId    String
  courtId         String?
  matchId         String?
  playerId        String?
  
  // Action
  action          VenueFlowAction
  status          String            @default("COMPLETED") // PENDING, COMPLETED, FAILED
  
  // Details
  oldState        String?           // JSON
  newState        String?           // JSON
  reason          String?
  
  // Actor
  performedBy     String?           // User ID or 'SYSTEM'
  performedByRole String?           // PLAYER, ADMIN, DIRECTOR, SYSTEM
  
  // Override tracking
  isOverride      Boolean           @default(false)
  overrideReason  String?
  
  // Timing
  durationMs      Int?
  
  createdAt       DateTime          @default(now())
  
  tournament      Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  court           Court?            @relation(fields: [courtId], references: [id])
  match           Match?            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player          User?             @relation(fields: [playerId], references: [id])
  
  @@index([tournamentId, createdAt])
  @@index([action, createdAt])
  @@index([matchId])
  @@index([courtId])
}

// Match Queue for Dynamic Scheduling
model MatchQueue {
  id              String    @id @default(cuid())
  tournamentId    String
  matchId         String    @unique
  
  // Queue position
  position        Int
  priority        Int       @default(0)  // Higher = more important
  
  // Readiness
  readiness       MatchReadiness @default(NOT_READY)
  readyAt         DateTime? // When both players checked in
  
  // Assignment
  assignedCourtId String?
  assignedAt      DateTime?
  
  // Status
  status          String    @default("QUEUED") // QUEUED, ASSIGNED, PLAYING, COMPLETED
  
  // Timing
  queuedAt        DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  match           Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  @@index([tournamentId, position])
  @@index([tournamentId, readiness])
  @@index([tournamentId, status])
}

// Court Health Alert
model VenueHealthAlert {
  id              String    @id @default(cuid())
  tournamentId    String
  courtId         String?
  
  // Alert type
  alertType       String    // IDLE_COURT, UNASSIGNED_READY_MATCH, NO_SHOW_PENDING, CHECKIN_BACKLOG
  severity        String    @default("WARNING") // INFO, WARNING, CRITICAL
  
  // Details
  message         String
  metadata        String?   // JSON
  
  // Resolution
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?
  resolution      String?
  
  createdAt       DateTime  @default(now())
  
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  
  @@index([tournamentId, isResolved, createdAt])
  @@index([alertType, severity])
}

