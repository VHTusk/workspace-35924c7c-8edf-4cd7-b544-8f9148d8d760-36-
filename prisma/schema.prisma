}

// Abuse Detection Patterns (v4.4.0)
enum AbusePattern {
  MULTIPLE_ACCOUNTS_SAME_DEVICE   // More than 3 accounts from same device
  RAPID_REGISTRATIONS             // Multiple registrations in short time
  SUSPICIOUS_TOURNAMENT_REGISTRATIONS // Bot-like tournament registration patterns
  BOT_REGISTRATION_PATTERN        // Automated bot registration detection
  SUSPICIOUS_PAYMENT_PATTERN      // Multiple failed payments, rapid payment after registration
  IMPOSSIBLE_TRAVEL               // Login from different countries within hours
  CREDENTIAL_STUFFING             // Multiple failed login attempts with different credentials
}

// Abuse Severity Level
enum AbuseSeverity {
  LOW       // Minor suspicious activity, monitoring recommended
  MEDIUM    // Suspicious pattern detected, investigation recommended
  HIGH      // Clear abuse pattern, immediate action recommended
  CRITICAL  // Severe abuse, automatic blocking triggered
}

// Leaderboard Type (v4.5.0) - Precomputation worker system
enum LeaderboardType {
  CITY
  DISTRICT
  STATE
  NATIONAL
  TOURNAMENT
}

enum PlayerScoreStatus {
  PENDING
  CONFIRMED
  DISPUTED
}

enum MatchVerificationStatus {
  PENDING
  VERIFIED
  DISPUTED
}

enum ScoringMode {
  STAFF_ONLY
  PLAYER_SELF
  HYBRID
}

enum OrgPlanTier {
  BASIC
  PRO
  ENTERPRISE
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLISTED
}

enum RosterRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum PlayerOrgType {
  EMPLOYEE      // Regular employee of the organization
  CONTRACTED    // Has a contract with the org (not employee)
  INDEPENDENT   // Not associated with any org
}

enum VerificationStatus {
  NONE          // No verification requested
  PENDING       // ID uploaded, pending verification
  VERIFIED      // Verified by org admin
  REJECTED      // Rejected by org admin
}

enum ContractStatus {
  PENDING       // Awaiting admin verification
  ACTIVE        // Verified and active
  EXPIRED       // Contract ended
  TERMINATED    // Contract terminated early
  REJECTED      // Rejected by admin
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// Profession Layer (v3.53.0) - Association-backed profession tagging
// Only structured professions with formal associations / councils / statutory bodies
enum Profession {
  // Medical & Allied (Statutory Bodies)
  DOCTOR
  DENTIST
  NURSE
  PHARMACIST
  PHYSIOTHERAPIST
  RADIOLOGIST
  AYURVEDIC_DOCTOR
  HOMEOPATHIC_DOCTOR

  // Legal
  LAWYER
  COMPANY_SECRETARY
  NOTARY

  // Finance & Audit
  CHARTERED_ACCOUNTANT
  COST_ACCOUNTANT
  ACTUARY

  // Engineering & Architecture
  ARCHITECT
  ENGINEER
  TOWN_PLANNER

  // Education
  TEACHER
  PROFESSOR

  // Media
  JOURNALIST

  // Real Estate
  REAL_ESTATE_AGENT

  // Technical & IT
  INSURANCE_AGENT
  STOCK_BROKER
  MUTUAL_FUND_DISTRIBUTOR

  // Aviation
  PILOT
  AIRCRAFT_ENGINEER
  AIR_TRAFFIC_CONTROLLER

  // Construction
  STRUCTURAL_ENGINEER
  CONTRACTOR

  // Agriculture
  AGRICULTURAL_SCIENTIST
  VETERINARIAN

  // Sports Governance
  COACH
  REFEREE

  // Fallback
