}

enum ProfessionVerificationStatus {
  NONE            // No verification requested
  SELF_DECLARED   // User declared but not verified
  PENDING         // Documents uploaded, pending review
  VERIFIED        // Profession verified by admin
  REJECTED        // Verification rejected
}

// ============================================
// TEAM MODELS (for Doubles and Team tournaments)
// ============================================

model Team {
  id          String   @id @default(cuid())
  name        String
  sport       SportType
  captainId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Team type based on tournament format
  format      TournamentFormat @default(DOUBLES)

  // Team stats
  teamElo     Float    @default(1000)  // Team rating for doubles/team tournaments
  wins        Int      @default(0)
  losses      Int      @default(0)
  points      Int      @default(0)
  matchesPlayed Int    @default(0)

  // Status: PENDING (waiting for partner), ACTIVE (team ready), INACTIVE (soft delete)
  status      TeamStatus @default(PENDING)

  // Relations
  captain     User     @relation("TeamCaptain", fields: [captainId], references: [id])
  members     TeamMember[]
  invitations TeamInvitation[]
  tournamentTeams TournamentTeam[]
  matchesAsA  Match[]  @relation("TeamA")
  matchesAsB  Match[]  @relation("TeamB")
  bracketMatchesAsA BracketMatch[] @relation("BracketTeamA")
  bracketMatchesAsB BracketMatch[] @relation("BracketTeamB")
  prizePayouts PrizePayout[]

  @@unique([name, sport])
  @@index([sport, status])
  @@index([sport, teamElo])
  @@index([captainId])
}

enum TeamStatus {
  PENDING   // Waiting for partner to accept invitation
  ACTIVE    // Team is fully formed and ready
  INACTIVE  // Soft deleted
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("MEMBER") // CAPTAIN, MEMBER
  joinedAt DateTime @default(now())

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TournamentTeam {
  id              String            @id @default(cuid())
  tournamentId    String
  teamId          String
  status          RegistrationStatus @default(PENDING)
  paymentId       String?
  amount          Int
  registeredAt    DateTime          @default(now())
  cancelledAt     DateTime?
  refundId        String?
  refundAmount    Int?

  tournament      Tournament        @relation(fields: [tournamentId], references: [id])
  team            Team              @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, teamId])
  @@index([teamId])
  @@index([status])
  @@index([tournamentId, status])
}

// Team Invitation for doubles/team partner invites
model TeamInvitation {
  id          String   @id @default(cuid())
  teamId      String
  inviterId   String   // Captain who sent the invite
  inviteeId   String   // Partner being invited
  status      TeamInvitationStatus @default(PENDING)
  message     String?  // Optional message from inviter
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  respondedAt DateTime?

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter     User     @relation("TeamInviter", fields: [inviterId], references: [id])
  invitee     User     @relation("TeamInvitee", fields: [inviteeId], references: [id])

  @@unique([teamId, inviteeId])
  @@index([inviteeId, status])
  @@index([status, expiresAt])
}

enum TeamInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

// ============================================
// MODELS
// ============================================

model User {
  id            String   @id @default(cuid())
  sport         SportType
  role          Role     @default(PLAYER)
  accountTier   AccountTier @default(FAN)  // FAN (free) or PLAYER (paid)

  // Auth fields
  email         String?
  password      String?
  phone         String?
  googleId      String?

  // Profile fields
  firstName     String
  lastName      String
  dob           DateTime?
  gender        GenderCategory?

  // Profile Picture
  photoUrl      String?

  // Bio/About
  bio           String?   // Short player biography (max 500 chars)

  // Location
  address       String?   // Full address (street, building, etc.)
  city          String?
  district      String?
  state         String?
  pinCode       String?
  
  // Emergency Contact (for tournament safety)
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRelation String?  // e.g., "Spouse", "Parent", "Sibling"
  
  affiliatedOrgId String?
  identityLocked Boolean @default(false)

  // Dual rating system
  hiddenElo     Float    @default(1500)
  visiblePoints Int      @default(0)

  // Email verification (legacy fields - kept for backward compatibility)
  emailVerifyToken  String?
  emailVerifyExpiry DateTime?
  verified          Boolean @default(false)
  verifiedAt        DateTime?

  // Email verification (new system - v4.3.0)
  emailVerified          Boolean  @default(false)
  emailVerifiedAt        DateTime?
  emailVerificationToken String?  @unique
  emailVerificationSentAt DateTime?

  // Legal consent
  tosAcceptedAt     DateTime?
  privacyAcceptedAt DateTime?

  // Preferences
  language      String   @default("en")

  // Privacy settings (v4.3.0 Enhanced)
  profileVisibility       ProfileVisibility     @default(PUBLIC)
  hideElo                 Boolean               @default(false)
  showOnLeaderboard       Boolean               @default(true)
  showPhone               Boolean               @default(false)
  showEmail               Boolean               @default(false)
  showRealName            Boolean               @default(true)
  showLocation            Boolean               @default(true)
  showTournamentHistory   Boolean               @default(true)
  allowFriendRequestsFrom FriendRequestSetting  @default(EVERYONE)
  allowMessagesFrom       MessageSetting        @default(EVERYONE)

  // Profession Layer (v3.53.0) - Association-backed profession
  profession             Profession?
  professionMembershipNumber String?            // Association membership/registration number
  professionGoverningBody String?               // Governing body name (auto-populated based on profession)
  professionVerified     ProfessionVerificationStatus @default(NONE)
  professionDocumentUrl  String?               // Uploaded proof document
  professionVerifiedAt   DateTime?
  professionVerifiedBy   String?               // Admin who verified
  showProfessionPublicly Boolean @default(false)

  // Organization relationship
  playerOrgType       PlayerOrgType      @default(INDEPENDENT)
  verificationStatus  VerificationStatus @default(NONE)
  idDocumentUrl       String?
  idDocumentType      String?            // passport, aadhaar, employee_id, etc.
  orgVerifiedAt       DateTime?
  orgVerifiedBy       String?            // User ID of org admin who verified
  verificationNotes   String?

  // Account status
  isActive          Boolean  @default(true)
  deactivatedAt     DateTime?
  deactivationReason String?
  profileUpdatedAt  DateTime?   // Last time profile was updated

  // Account lockout
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?

  // Anonymization
  isAnonymized   Boolean  @default(false)
  anonymizedAt   DateTime?

  // GDPR Compliance (v3.26.0)
  gdprDeletionRequestedAt DateTime?
  gdprDeletionScheduledFor DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  sessions              Session[]
  subscriptions         Subscription[]
  tournamentRegs        TournamentRegistration[]
  matchesAsA            Match[]           @relation("PlayerA")
  matchesAsB            Match[]           @relation("PlayerB")
  matchesUpdated        Match[]           @relation("MatchUpdater")
  affiliatedOrg         Organization?     @relation("AffiliatedPlayers", fields: [affiliatedOrgId], references: [id])
  disputes              Dispute[]
  rating                PlayerRating?
  achievements          PlayerAchievement[]
  notifications         Notification[]
  tournamentResults     TournamentResult[]
  prizePayouts          PrizePayoutRecord[]
  prizePayoutsMarked    PrizePayoutRecord[] @relation("PayoutMarker")
  mfaSecret             MfaSecret?
  mfaRecoveryCodes      MfaRecoveryCode[]
  notificationPref      NotificationPreference?
  orgAdminRoles         OrgAdmin[]
  orgAdminInvites       OrgAdmin[]        @relation("OrgAdminInviter")
  bracketsGenerated     Bracket[]         @relation("BracketGenerator")
  auditLogs             AuditLog[]        @relation("AuditActor")
  orgRosterEntries      OrgRosterPlayer[]
  rosterRequests        OrgRosterRequest[]
  wallet                Wallet?
  transferCooldowns     TransferCooldown[]
  identityChangeReqs    IdentityChangeRequest[]
  staffAssignments      TournamentStaff[]
  // New relations for top 10 features
  availabilities        PlayerAvailability[]
  blockedUsers          BlockedPlayer[]   @relation("Blocker")
  blockedBy             BlockedPlayer[]   @relation("Blocked")
  conversationParticipants ConversationParticipant[]
  sentMessages          Message[]
  leaderboardSnapshots  LeaderboardSnapshot[]
  referrals             Referral[]        @relation("Referrer")
  referredBy            Referral[]        @relation("Referee")

  // Referral code for this user
  referralCode          String?           @unique

  // Follow system
  following             UserFollow[]      @relation("UserFollower")
  followers             UserFollow[]      @relation("UserFollowing")
  followingOrgs         UserFollowsOrg[]
  followedByOrgs        OrgFollowsUser[]
  
  // Notification settings
  emailNotificationSettings EmailNotificationSetting[]
  whatsappNotificationSettings WhatsAppNotificationSetting[]
  pushNotificationSettings PushNotificationSetting[]
  
  // Milestones
  milestones            Milestone[]

  // Tournament reminders
  tournamentReminders   TournamentReminder[]
  matchReminders        MatchReminder[]  // v3.45.0
  
  // Venue Flow (v3.47.0)
  matchCheckIns         MatchCheckIn[]
  venueFlowLogs         VenueFlowLog[]

  // Contract relations
  playerContracts       PlayerContract[]  @relation("PlayerContracts")
  interOrgTeamPlayers   InterOrgTeamPlayer[]
  idVerifications       PlayerIdVerification[]

  // GDPR Compliance (v3.26.0)
  gdprConsents          GdprConsent[]

  // Team memberships (for Doubles/Team tournaments)
  teamMemberships       TeamMember[]
  captainedTeams        Team[]            @relation("TeamCaptain")
  sentTeamInvitations   TeamInvitation[]  @relation("TeamInviter")
  receivedTeamInvitations TeamInvitation[] @relation("TeamInvitee")

  // Prize payouts (new system)
  prizePayoutsNew       PrizePayout[]

  // Admin hierarchy (v3.46.0)
  adminAssignments      AdminAssignment[]
  adminMetrics          AdminMetrics?

  // Corporate Mode Relations (v3.54.0)
  employeeProfiles      Employee[]
  repPlayerProfile       RepPlayer[]

  // School/College Mode Relations (v3.55.0)
  studentProfile         Student?

  // Player Experience Enhancement (v3.71.0)
  skillMetrics           PlayerSkillMetrics[]
  streaks                PlayerStreak[]
  activityFeedItems      PlayerActivityFeedItem[]
  friendActivity         FriendActivity?
  trophies               PlayerTrophy[]
  quickTeamRequests      QuickTeamRequest[]
  tournamentRecommendations PlayerTournamentRecommendation[]

  // Media Relations (v3.72.0)
  spotlightImages        PlayerSpotlightImage[]

  // Duel Mode Relations (v3.73.0)
  hostedDuels            DuelMatch[]       @relation("DuelHost")
  wonDuels               DuelMatch[]       @relation("DuelWinner")
  duelRegistrations      DuelRegistration[]
  cityDuelEntries        CityDuelEntry[]

  // Rating Snapshot Relations (Glicko-2 Lite)
  ratingSnapshots        RatingSnapshot[]

  // Push Notifications (v3.81.0)
  pushDevices            PushDevice[]
  
  // Retention & Intelligence Layer (v3.51.0)
  reengagementLogs       ReengagementLog[]
  playerIncentives       PlayerIncentive[]
  feedbackRequests       FeedbackRequest[]
  feedbacks              Feedback[]
  scheduledNotifications ScheduledNotification[]
  batchedNotifications   BatchedNotification[]

  // Refresh Token Authentication (v3.83.0)
  refreshTokens          RefreshToken[]
  
  // Referee Profile (v3.83.0)
  refereeProfile         RefereeProfile?

  // Abuse Detection (v4.4.0)
  deviceFingerprints     DeviceFingerprint[]
  abuseEvents            AbuseEvent[]        @relation("AbuseEventUser")
  reportedAbuseEvents    AbuseEvent[]        @relation("AbuseEventReporter")

  // Appeals (v4.5.0)
  appeals                Appeal[]
  reviewedAppeals        Appeal[]            @relation("AppealReviewer")

  // Coupon System (v4.6.0)
  couponUsages           CouponUsage[]
  uploadedFiles          UploadedFile[]

  // Corporate Architecture v4.0 Relations
  orgMemberships         OrganizationMembership[]
  orgAuditLogs           OrgAuditLog[]

  @@unique([email, sport])
  @@unique([phone, sport])
  @@unique([googleId, sport])
  @@index([sport, hiddenElo])
  @@index([sport, visiblePoints])
  @@index([sport, isActive])
}

model Session {
  id            String      @id @default(cuid())
  token         String      @unique
  userId        String?
  orgId         String?
  sport         SportType
  accountType   AccountType
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  lastActivityAt DateTime   @default(now())

  // Org operator identity (for shared-credential sessions)
  operatorName  String?
  operatorEmail String?

  // Refresh Token linkage (v3.83.0)
  refreshTokenId String?    @unique // Links to RefreshToken for session-refresh token binding
  
  // Device tracking (v3.83.0)
  deviceFingerprint String? // Unique device identifier for multi-device tracking
  isRedisBacked Boolean @default(false) // Whether session is stored in Redis for distributed systems

  user          User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  org           Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refreshToken  RefreshToken? @relation(fields: [refreshTokenId], references: [id], onDelete: SetNull)

  @@index([userId, expiresAt])
  @@index([token])
  @@index([refreshTokenId])
  @@index([deviceFingerprint])
}

// ============================================
// REFRESH TOKEN SYSTEM (v3.83.0)
// Secure refresh token management with device tracking
// ============================================

model RefreshToken {
  id            String    @id @default(cuid())
  token         String    @unique  // Secure random token (hashed)
  userId        String
  
  // Device tracking
  deviceInfo    String?   // JSON: { userAgent, platform, os, browser }
  deviceName    String?   // "iPhone 14 Pro", "Chrome on Windows"
  deviceFingerprint String? // Unique device identifier
  ipAddress     String?   // IP address at token creation
  
  // Token metadata
  expiresAt     DateTime  // 30 days from creation
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime? // Updated each time token is used
  
  // Security
  isRevoked     Boolean   @default(false)
  revokedAt     DateTime?
  revokedReason String?   // "user_logout", "security_breach", "admin_action", "password_change"
  
  // Session binding
  session       Session?
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, expiresAt])
  @@index([token])
  @@index([userId, isRevoked])
  @@index([deviceFingerprint])
}

// ============================================
// REFEREE PROFILE SYSTEM (v3.83.0)
// Match official management
// ============================================

model RefereeProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  sport           SportType
  refereeRole     RefereeRole @default(REFEREE)  // Referee role level
  
  // Certification details
  certifications  String?   // JSON: [{ name, issuer, date, expiryDate, documentUrl }]
  
  // Experience tracking
  matchCount      Int       @default(0)  // Total matches officiated
  tournamentCount Int       @default(0)  // Total tournaments officiated
  
  // Performance rating
  rating          Float     @default(0)  // Average rating from players/directors (0-5)
  ratingCount     Int       @default(0)  // Number of ratings received
  
  // Availability
  isActive        Boolean   @default(true)  // Available for assignments
  availableRegions String?  // JSON: ["MH", "GJ", "RJ"] - States available for
  
  // Specialization
  specialization  String?   // "CHAMPIONSHIP", "LEAGUE", "GRASSROOTS", "ALL"
  
  // Contact for assignments
  contactPhone    String?
  contactEmail    String?
  preferredContact String?  @default("PHONE") // PHONE, EMAIL, WHATSAPP
  
  // Admin verification
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  verifiedById    String?   // Admin who verified
  
  // Audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([sport, isActive])
  @@index([sport, rating])
  @@index([userId, sport])
}

// Director Magic Link (v3.52.0) - For temporary director access
model DirectorMagicLink {
  id            String    @id @default(cuid())
  tournamentId  String
  token         String    @unique
  phone         String    // Director phone number
  email         String?   // Director email (optional)
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tournamentId])
  @@index([expiresAt])
}

// Director Session (v3.52.0) - Session for tournament directors
model DirectorSession {
  id            String    @id @default(cuid())
  tournamentId  String
  token         String    @unique
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  lastActivityAt DateTime @default(now())

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tournamentId, expiresAt])
}

model Match {
  id              String                @id @default(cuid())
  sport           SportType
  tournamentId    String?

  // Individual player references (for INDIVIDUAL format)
  playerAId       String?
  playerBId       String?

  // Team references (for DOUBLES/TEAM format)
  teamAId         String?
  teamBId         String?

  scoreA          Int?
  scoreB          Int?
  winnerId        String?
  winnerTeamId    String?               // For team matches

  outcome         MatchOutcome?
  outcomeReason   String?

  // Points awarded - locked at completion
  pointsA         Int?
  pointsB         Int?
  tournamentScope TournamentScope?

  // Elo changes
  eloChangeA     Float?
  eloChangeB     Float?

  // Scheduling
  scheduledTime  DateTime?
  courtName      String?

  // Player-confirmed scoring
  submittedById      String?
  playerScoreStatus  PlayerScoreStatus?
  verificationStatus MatchVerificationStatus @default(PENDING)
  verificationDeadline DateTime?

  // Referee
  refereeId      String?
  refereeName    String?

  playedAt       DateTime    @default(now())
  updatedById    String?
  updatedAt      DateTime    @updatedAt

  // Offline sync
  enteredOffline Boolean     @default(false)
  syncedAt       DateTime?
  rowVersion     Int         @default(1)

  // Relations
  tournament     Tournament? @relation(fields: [tournamentId], references: [id])
  playerA        User?       @relation("PlayerA", fields: [playerAId], references: [id])
  playerB        User?       @relation("PlayerB", fields: [playerBId], references: [id])
  teamA          Team?       @relation("TeamA", fields: [teamAId], references: [id])
  teamB          Team?       @relation("TeamB", fields: [teamBId], references: [id])
  updatedBy      User?       @relation("MatchUpdater", fields: [updatedById], references: [id])
  history        MatchResultHistory[]
  bracketMatch   BracketMatch?
  matchReminders MatchReminder[]  // v3.45.0
  
  // Venue Flow (v3.47.0)
  checkIns       MatchCheckIn[]
  courtAssignments CourtAssignment[]
  matchQueue     MatchQueue?
  venueFlowLogs  VenueFlowLog[]

  @@index([tournamentId])
  @@index([playerAId, playedAt])
  @@index([playerBId, playedAt])
  @@index([teamAId, playedAt])
  @@index([teamBId, playedAt])
  @@index([tournamentId, verificationStatus])
  @@index([tournamentId, playedAt])  // For match history queries by tournament
}

model Tournament {
  id                    String                @id @default(cuid())
  name                  String
  sport                 SportType
  type                  TournamentType
  scope                 TournamentScope?
  location              String
  startDate             DateTime
  endDate               DateTime
  regDeadline           DateTime
  prizePool             Int
  maxPlayers            Int
  entryFee              Int                   @default(0)
  maxPlayersPerOrg      Int?

  // Tournament format: INDIVIDUAL (1v1), DOUBLES (2v2), TEAM (3-4 players)
  format                TournamentFormat      @default(INDIVIDUAL)
  // For team/doubles tournaments
  teamSize              Int?                  // Number of players per team (2 for doubles, 3-4 for team)
  maxTeams              Int?                  // Max number of teams (alternative to maxPlayers for team tournaments)

  // Early bird & discounts
  earlyBirdFee          Int?
  earlyBirdDeadline     DateTime?
  groupDiscountMin      Int?
  groupDiscountPercent  Int?

  bracketFormat         BracketFormat?

  // Geographic scope
  city                  String?
  district              String?
  state                 String?

  // Venue location with Google Maps
  venueGoogleMapsUrl    String?             // Google Maps link for venue location

  // Tournament Manager (mandatory)
  managerName           String              // Tournament manager name
  managerPhone          String              // Manager phone number
  managerWhatsApp       String?             // Manager WhatsApp number (optional, defaults to phone)

  // Contact Person (optional)
  contactPersonName     String?             // Additional contact person name
  contactPersonPhone    String?             // Contact person phone
  contactPersonWhatsApp String?             // Contact person WhatsApp (optional)

  orgId                 String?
  ageMin                Int?
  ageMax                Int?
  gender                GenderCategory?
  isPublic              Boolean               @default(false)
  status                TournamentStatus      @default(DRAFT)
  scoringMode           ScoringMode           @default(STAFF_ONLY)
  rosterLockDate        DateTime?

  createdById           String?
  templateId            String?             // Source template if created from template
  seriesId              String?             // Series this tournament belongs to
  seriesPoints          Int?                // Points awarded for this tournament in series
  seriesPosition        Int?                // Position within series (e.g., Tournament 3 of 10)

  // Tournament Autopilot Settings (v3.45.0)
  autopilotEnabled      Boolean               @default(false)  // Master switch for autopilot
  autoCloseRegistration Boolean               @default(true)   // Auto-close at regDeadline
  autoGenerateBracket   Boolean               @default(true)   // Auto-generate bracket after close
  autoStartTournament   Boolean               @default(true)   // Auto-start at startDate
  autoAdvanceWinner     Boolean               @default(true)   // Auto-advance winners after match completion
  autoPromoteWaitlist   Boolean               @default(true)   // Auto-promote from waitlist on withdrawal

  // Autopilot tracking
  registrationClosedAt DateTime?              // When registration was auto-closed
  bracketGeneratedAt   DateTime?              // When bracket was auto-generated
  tournamentStartedAt  DateTime?              // When tournament was auto-started

  // Tournament Director (v3.52.0) - Optional, can be assigned later
  directorName         String?                // Director name
  directorPhone        String?                // Director phone
  directorEmail        String?                // Director email (optional)
  directorUsername     String?                // Generated username for login
  directorPasswordHash String?                // Hashed password
  directorCredentialsSent Boolean @default(false) // Whether credentials were shared
  directorAssignedById String?                // Who assigned the director
  directorAssignedAt   DateTime?              // When director was assigned
  showDirectorContact  Boolean @default(false) // Privacy: show to registered players
  
  // Venue-Day Escalation (v3.52.0)
  venueEscalationActive    Boolean @default(false) // Emergency escalation triggered
  venueEscalationTriggeredAt DateTime?             // When escalation was triggered
  venueEscalationTriggeredById String?             // Admin who triggered
  venueEscalationReason    String?                 // Reason for escalation

  // Profession Layer (v3.53.0) - Profession-exclusive tournaments
  isProfessionExclusive    Boolean @default(false) // Only certain professions can register
  allowedProfessions       String?               // JSON array of allowed professions: '["LAWYER","DOCTOR"]'

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  // Relations
  hostOrg               Organization?         @relation("IntraOrgHost", fields: [orgId], references: [id])
  series                TournamentSeries?     @relation(fields: [seriesId], references: [id])
  registrations         TournamentRegistration[]
  orgRegistrations      OrgTournamentRegistration[]
  teamRegistrations     TournamentTeam[]      // For team/doubles tournaments
  matches               Match[]
  waitlist              TournamentWaitlist[]
  bracket               Bracket?
  sponsors              TournamentSponsor[]
  media                 TournamentMedia[]
  mediaItems            TournamentMediaItem[] // Enhanced media gallery
  videoHighlights       VideoHighlight[]
  tournamentRecap       TournamentRecap?
  checkins              TournamentCheckin[]
  staff                 TournamentStaff[]
  scheduleSlots         ScheduleSlot[]
  announcements         TournamentAnnouncement[]
  results               TournamentResult[]
  prizePayouts          PrizePayoutRecord[]
  prizeDistributions    PrizeDistribution[]
  prizePayoutRecords    PrizePayout[]
  interOrgTeamSelections InterOrgTeamSelection[]
  paymentLedgers        PaymentLedger[]      // Tournament-specific payment records
  reminders             TournamentReminder[] // Tournament reminder tracking
  autopilotLogs         AutopilotLog[]       // v3.45.0 - Autopilot action logs
  
  // Venue Flow (v3.47.0)
  courts                Court[]
  venueFlowConfig       VenueFlowConfig?
  matchQueue            MatchQueue[]
  venueHealthAlerts     VenueHealthAlert[]
  venueFlowLogs         VenueFlowLog[]
  
  // Financial Safety Layer (v3.49.0)
  refundPolicy          RefundPolicy?
  refundJobs            RefundJob[]
  financeSnapshot       TournamentFinanceSnapshot?
  cancellationLogs      CancellationLog[]
  paymentRecoveries     PaymentRecovery[]
  
  // Director Management (v3.52.0)
  directorMagicLinks    DirectorMagicLink[]
  directorSessions      DirectorSession[]

  // Corporate Mode Relations (v3.54.0)
  employeeInvitations    EmployeeInvitation[]
  employeeParticipations EmployeeTournamentParticipation[]
  repSquadRegistrations  RepSquadTournamentRegistration[]

  // School/College Mode Relations (v3.55.0)
  academicTeamRegistrations AcademicTeamRegistration[]

  // Media Relations (v3.72.0)
  galleryImages     TournamentGalleryImage[]

  // Coupon System (v4.6.0)
  coupons           Coupon[]

  @@index([sport, status])
  @@index([sport, type])
  @@index([city, sport, status])
  @@index([state, sport, status])
  @@index([sport, isPublic, status])
}

model Organization {
