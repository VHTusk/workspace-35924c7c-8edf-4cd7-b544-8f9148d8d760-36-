// VALORHIVE v3.80 - Complete Prisma Schema
// Multi-Sport Tournament Platform: Cornhole & Darts
// Production-ready with PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum SportType {
  CORNHOLE
  DARTS
}

enum Role {
  PLAYER
  ORG_ADMIN
  SUB_ADMIN
  ADMIN
  TOURNAMENT_DIRECTOR
}

// Admin Role Hierarchy (v4.15.0) - Simplified 5-level hierarchy
// Hierarchy: SUPER_ADMIN > SPORT_ADMIN > STATE_ADMIN > DISTRICT_ADMIN > TOURNAMENT_DIRECTOR
// REFEREE is now a separate non-admin role (see RefereeProfile model)
enum AdminRole {
  SUPER_ADMIN      // Cross-sport, cross-geography (1-2 people)
  SPORT_ADMIN      // One sport, all geography (1-2 per sport)
  STATE_ADMIN      // One sport, one state (per state per sport)
  DISTRICT_ADMIN   // One sport, one district (per district per sport)
  TOURNAMENT_DIRECTOR // Assigned tournaments only
}

// Referee Role - Separate non-admin role for match officials
enum RefereeRole {
  REFEREE          // Match official for specific sport
  HEAD_REFEREE     // Senior referee with additional responsibilities
  ASSISTANT_REFEREE // Supporting referee role
}

enum AccountType {
  PLAYER
  ORG
}

enum AccountTier {
  FAN      // Free tier - spectator only
  PLAYER   // Paid tier - can compete
}

enum OrgType {
  SCHOOL
  COLLEGE
  CLUB
  ASSOCIATION
  CORPORATE
  GOVT_ORGANISATION
  ACADEMY
  OTHER
}

enum OrgAdminRole {
  PRIMARY
  ADMIN
  STAFF
}

enum BracketSide {
  WINNERS
  LOSERS
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
}

enum TournamentType {
  INDIVIDUAL
  INTER_ORG
  INTRA_ORG
}

// Tournament Format - Individual (1v1), Doubles (2v2), or Team (3-4 players)
enum TournamentFormat {
  INDIVIDUAL  // 1v1 matches
  DOUBLES     // 2v2 matches (teams of 2)
  TEAM        // Team matches (3-4 players per team)
}

enum TournamentScope {
  CITY
  DISTRICT
  STATE
  NATIONAL
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  BRACKET_GENERATED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum GenderCategory {
  MALE
  FEMALE
  MIXED
}

// Privacy Settings Enums (v4.3.0)
enum ProfileVisibility {
  PUBLIC        // Anyone can view profile
  FRIENDS_ONLY  // Only friends can view profile
  PRIVATE       // Only the user can view their profile
}

enum FriendRequestSetting {
  EVERYONE         // Anyone can send friend requests
  FRIENDS_OF_FRIENDS // Only friends of friends can send requests
  NO_ONE           // No one can send friend requests
}

enum MessageSetting {
  EVERYONE  // Anyone can send messages
  FRIENDS   // Only friends can send messages
  NO_ONE    // No one can send messages
}

enum MatchOutcome {
  PLAYED
  WALKOVER
  NO_SHOW
  FORFEIT
  BYE
}

enum BracketFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
}

enum BracketMatchStatus {
  PENDING
  LIVE
  COMPLETED
  BYE
}

// Venue Flow Enums (v3.47.0)
enum CheckInStatus {
  NOT_CHECKED_IN   // Player has not checked in
  CHECKED_IN       // Player is checked in and ready
  EXTENDED         // Grace period extended by admin
  NO_SHOW_DETECTED // System detected potential no-show
  NO_SHOW_CONFIRMED // Director confirmed no-show
  FORFEIT          // Player forfeited
}

enum CourtStatus {
  AVAILABLE        // Court is free
  OCCUPIED         // Court has an active match
  MAINTENANCE      // Court under maintenance
  RESERVED         // Court reserved for specific match
}

enum MatchReadiness {
  NOT_READY        // Players not checked in
  PARTIAL_READY    // Only one player checked in
  READY            // Both players checked in, waiting for court
  ASSIGNED         // Match assigned to court
  IN_PROGRESS      // Match is live
}

enum VenueFlowAction {
