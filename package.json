{
  "name": "valorhive",
  "version": "4.14.0",
  "private": true,
  "description": "VALORHIVE - Multi-Sport Tournament Platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "mini-services/*"
  ],
  "scripts": {
    "dev": "next dev --webpack -p 3000",
    "build": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "build:worker": "tsc -p tsconfig.worker.json",
    "start": "next start",
    "start:worker": "NODE_ENV=production node dist/workers/index.js",
    "lint": "eslint .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:prod": "tsx scripts/migrate-production.ts",
    "db:migrate:prod:dry": "tsx scripts/migrate-production.ts --dry-run",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "prod:migrate": "prisma db push --skip-generate && prisma generate",
    "prod:check": "prisma validate",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:prod": "docker-compose -f docker-compose.yml up -d",
    "docker:prod:down": "docker-compose down",
    "redis:cli": "redis-cli -h localhost -p 6379",
    "queue:dashboard": "bull-board --port 3002"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.600.0",
